{%- comment -%}
  founder-whatsapp.liquid — Merged FounderStory & WhatsAppCTA sections
  Include: {% render 'founder-whatsapp' %}
{%- endcomment -%}

{%- style -%}
  /* ===== Shared ===== */
  .fw-section {
    padding: 5rem 1rem;
    overflow: hidden;
  }
  @media (min-width: 640px) {
    .fw-section { padding: 7rem 1.5rem; }
  }
  @media (min-width: 1024px) {
    .fw-section { padding: 7rem 2rem; }
  }
  .fw-container {
    max-width: 80rem;
    margin: 0 auto;
  }
  .fw-animate {
    opacity: 0;
    transition: opacity 1s cubic-bezier(0.22, 1, 0.36, 1), transform 1s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .fw-animate.is-visible {
    opacity: 1;
    transform: none !important;
  }

  /* ===== Founder Story ===== */
  #story {
    background: var(--background, #0d0d0d);
    color: var(--foreground, #fff);
  }
  .story-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .story-grid { grid-template-columns: 1fr 1fr; gap: 5rem; }
  }
  .story-image-wrap {
    position: relative;
  }
  .story-image {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 4;
  }
  .story-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .story-accent-block {
    position: absolute;
    bottom: -1rem;
    right: -1rem;
    width: 6rem;
    height: 8rem;
    background: var(--accent, #C41E1E);
    z-index: -1;
    transform-origin: bottom;
    transform: scaleY(0);
    transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.5s;
  }
  .story-image-wrap.is-visible .story-accent-block {
    transform: scaleY(1);
  }
  .story-divider {
    width: 3rem;
    height: 0.125rem;
    background: var(--accent, #C41E1E);
    margin-bottom: 2rem;
    transform-origin: left;
    transform: scaleX(0);
    transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.2s;
  }
  .story-content.is-visible .story-divider {
    transform: scaleX(1);
  }
  .story-tag {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    font-family: var(--font-body, sans-serif);
    color: var(--accent, #C41E1E);
    margin-bottom: 1rem;
  }
  .story-title {
    font-family: var(--font-heading, serif);
    font-size: 1.875rem;
    font-weight: bold;
    line-height: 1.2;
    margin-bottom: 2rem;
  }
  @media (min-width: 640px) { .story-title { font-size: 2.25rem; } }
  @media (min-width: 768px) { .story-title { font-size: 3rem; } }
  .story-title span {
    color: var(--accent, #C41E1E);
    font-style: italic;
  }
  .story-text {
    color: var(--muted-foreground, #aaa);
    font-size: 0.875rem;
    line-height: 1.7;
    font-family: var(--font-body, sans-serif);
    margin-bottom: 1.25rem;
  }
  .story-signature {
    margin-top: 2.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s, transform 0.8s;
  }
  .story-content.is-visible .story-signature {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.6s;
  }
  .signature-line {
    width: 4rem;
    height: 0.125rem;
    background: rgba(255,255,255,0.2);
  }
  .signature-name {
    font-family: var(--font-heading, serif);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--foreground, #fff);
  }
  .signature-sub {
    font-size: 0.75rem;
    color: var(--muted-foreground, #aaa);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-family: var(--font-body, sans-serif);
  }

  /* ===== WhatsApp CTA ===== */
  #community {
    background: #fff;
  }
  .cta-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .cta-grid { grid-template-columns: 1fr 1fr; gap: 5rem; }
  }
  .cta-divider {
    width: 2.5rem;
    height: 0.125rem;
    background: #C41E1E;
    margin-bottom: 1.5rem;
    transform-origin: left;
    transform: scaleX(0);
    transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cta-left.is-visible .cta-divider {
    transform: scaleX(1);
  }
  .cta-title {
    font-family: var(--font-heading, serif);
    font-size: 2.25rem;
    font-weight: bold;
    color: #111;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }
  @media (min-width: 640px) { .cta-title { font-size: 3rem; } }
  @media (min-width: 768px) { .cta-title { font-size: 3.75rem; } }
  .cta-title span {
    color: #C41E1E;
    font-style: italic;
  }
  .cta-desc {
    color: #666;
    font-size: 0.875rem;
    line-height: 1.7;
    font-family: var(--font-body, sans-serif);
    max-width: 28rem;
    margin-bottom: 2.5rem;
  }
  @media (min-width: 640px) { .cta-desc { font-size: 1rem; } }
  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: #25D366;
    color: #fff;
    padding: 1rem 2rem;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: bold;
    text-decoration: none;
    transition: background 0.3s, transform 0.2s;
    font-family: var(--font-body, sans-serif);
  }
  .cta-button:hover {
    background: #1ebe5d;
    transform: scale(1.03);
  }
  .cta-button:active {
    transform: scale(0.97);
  }
  .cta-button svg {
    width: 1rem;
    height: 1rem;
  }
  .cta-button .arrow {
    transition: transform 0.3s;
  }
  .cta-button:hover .arrow {
    transform: translateX(4px);
  }
  .cta-note {
    color: #bbb;
    font-size: 0.6875rem;
    font-family: var(--font-body, sans-serif);
    letter-spacing: 0.05em;
    margin-top: 1rem;
  }
  .perks-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .perk-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem;
    background: #f7f4f0;
    transition: background 0.3s, transform 0.3s;
    cursor: default;
  }
  @media (min-width: 640px) {
    .perk-card { padding: 1.5rem; }
  }
  .perk-card:hover {
    background: #111;
    transform: translateX(6px);
  }
  .perk-card:hover .perk-title {
    color: #fff;
  }
  .perk-card:hover .perk-desc {
    color: rgba(255,255,255,0.5);
  }
  .perk-card:hover .perk-arrow {
    color: #fff;
    transform: translateX(4px);
  }
  .perk-icon {
    width: 2.75rem;
    height: 2.75rem;
    background: rgba(196,30,30,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.3s;
  }
  .perk-card:hover .perk-icon {
    background: rgba(196,30,30,0.2);
  }
  .perk-icon svg {
    width: 1.25rem;
    height: 1.25rem;
    color: #C41E1E;
  }
  .perk-title {
    font-family: var(--font-heading, serif);
    font-size: 1rem;
    font-weight: bold;
    color: #111;
    transition: color 0.3s;
  }
  .perk-desc {
    font-size: 0.75rem;
    color: #888;
    font-family: var(--font-body, sans-serif);
    margin-top: 0.125rem;
    transition: color 0.3s;
  }
  .perk-arrow {
    margin-left: auto;
    color: #ddd;
    transition: color 0.3s, transform 0.3s;
    width: 1rem;
    height: 1rem;
  }
{%- endstyle -%}

<!-- Founder Story Section -->
<section id="story" class="fw-section">
  <div class="fw-container">
    <div class="story-grid">
      <!-- Image -->
      <div class="story-image-wrap fw-animate" data-animate="fade-left" style="transform: translateX(-80px);">
        <div class="story-image">
          <img
            src="https://media.base44.com/images/public/6a0c6aec6e7da3d15bf1cbdd/7189e016d_generated_08d5fbf9.png"
            alt="Founder of URBNMYTH"
            loading="lazy"
          >
        </div>
        <div class="story-accent-block"></div>
      </div>

      <!-- Content -->
      <div class="story-content fw-animate" data-animate="fade-right" style="transform: translateX(80px);">
        <div class="story-divider"></div>
        <p class="story-tag">The Story Behind</p>
        <h2 class="story-title">
          Born From the Streets,<br>
          <span>Crafted for Legends</span>
        </h2>
        <div class="story-text">
          <p>URBNMYTH wasn't born in a boardroom — it was born in the streets, from late-night sketches, underground culture, and a relentless obsession with self-expression. We saw a gap between old-money elegance and raw street energy, and decided to bridge it.</p>
          <p>Every piece we create carries a story. From the gothic typography inspired by European heritage to the oversized silhouettes that define modern street culture — URBNMYTH is where timeless class meets unapologetic rebellion.</p>
          <p>Our mission is simple: give every individual the armor to walk into any room and own it. No myths, no pretense — just pure, unfiltered style.</p>
        </div>
        <div class="story-signature">
          <div class="signature-line"></div>
          <div>
            <p class="signature-name">URBNMYTH.IN</p>
            <p class="signature-sub">Est. 2025 • India</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WhatsApp CTA Section -->
<section id="community" class="fw-section">
  <div class="fw-container">
    <div class="cta-grid">
      <!-- Left: Text + CTA -->
      <div class="cta-left fw-animate" data-animate="fade-up" style="transform: translateY(40px);">
        <div class="cta-divider"></div>
        <h2 class="cta-title">
          Join the<br>
          <span>Inner Circle</span>
        </h2>
        <p class="cta-desc">
          The URBNMYTH WhatsApp community is where the real action happens. Drop alerts, style guides, member giveaways and direct access to the founder.
        </p>
        <a
          href="https://wa.me/your-number"
          target="_blank"
          rel="noopener noreferrer"
          class="cta-button"
        >
          <!-- MessageCircle icon -->
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          Join on WhatsApp
          <span class="arrow">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
        <p class="cta-note">Free to join • No spam • Only the good stuff</p>
      </div>

      <!-- Right: Perk cards -->
      <div class="perks-list">
        <!-- Perk 1: Early Drops -->
        <div class="perk-card fw-animate" data-animate="fade-left" style="transform: translateX(60px);">
          <div class="perk-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <div>
            <p class="perk-title">Early Drops</p>
            <p class="perk-desc">First access to every new release</p>
          </div>
          <div class="perk-arrow">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
        </div>

        <!-- Perk 2: Members Only -->
        <div class="perk-card fw-animate" data-animate="fade-left" style="transform: translateX(60px);">
          <div class="perk-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
          </div>
          <div>
            <p class="perk-title">Members Only</p>
            <p class="perk-desc">Exclusive deals & surprise offers</p>
          </div>
          <div class="perk-arrow">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
        </div>

        <!-- Perk 3: 5K+ Tribe -->
        <div class="perk-card fw-animate" data-animate="fade-left" style="transform: translateX(60px);">
          <div class="perk-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <div>
            <p class="perk-title">5K+ Tribe</p>
            <p class="perk-desc">Real community, real style talk</p>
          </div>
          <div class="perk-arrow">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function() {
    // Intersection Observer to trigger CSS animations when elements enter viewport
    const animatedElements = document.querySelectorAll('.fw-animate');
    if (!animatedElements.length) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          // If you want animation to play only once, unobserve after
          // observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });

    animatedElements.forEach(el => observer.observe(el));
  })();
</script>