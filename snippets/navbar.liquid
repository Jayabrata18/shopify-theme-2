{%- style -%}
/* ===== Core ===== */
.navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 50;
  transition: background 0.5s ease, box-shadow 0.5s ease;
  background: transparent;
  animation: slideDown 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  transform: translateY(-100%);
}
@keyframes slideDown { to { transform: translateY(0); } }

/* scrolled = dark bg → icons white */
.navbar.scrolled {
  background: rgba(0,0,0,0.95);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(255,255,255,0.1);
}

/* white-bg = light bg → icons black */
.navbar.white-bg {
  background: #fff;
  border-bottom: 1px solid #e8e8e8;
}

.navbar-container {
  max-width: 80rem;
  margin: 0 auto;
  padding: 0 1rem;
}
@media (min-width: 640px)  { .navbar-container { padding: 0 1.5rem; } }
@media (min-width: 1024px) { .navbar-container { padding: 0 2rem; } }

/* ===== Inner: 3 zones ===== */
.navbar-inner {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  /* height scales with viewport height */
  height: clamp(3.5rem, 8vh, 5rem);
}
@media (min-width: 640px)  { .navbar-inner { height: clamp(4rem, 9vh, 5.5rem); } }
@media (min-width: 1024px) { .navbar-inner { height: clamp(4.5rem, 10vh, 6rem); } }

.navbar-left  { display: flex; align-items: center; gap: 0.25rem; justify-content: flex-start; }
.navbar-right { display: flex; align-items: center; gap: 0.25rem; justify-content: flex-end; }

/* ===== Logo ===== */
.navbar-logo {
  display: flex; align-items: center; justify-content: center;
  text-decoration: none;
  animation: logoPulse 1.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  opacity: 0;
}
@keyframes logoPulse {
  0%   { opacity: 0; transform: scale(0.85); }
  60%  { opacity: 1; transform: scale(1.04); }
  100% { opacity: 1; transform: scale(1); }
}
.navbar-logo img {
  /* fluid logo: scales with viewport width */
  height: clamp(1.6rem, 4vw, 3rem);
  display: block;
  transition: filter 0.3s ease, transform 0.4s ease;
  filter: brightness(10);    /* white logo by default (transparent bg) */
}
/* When white-bg, tint logo red */
.navbar.white-bg .navbar-logo img {
  filter: brightness(0) saturate(100%) invert(10%) sepia(100%) saturate(6000%) hue-rotate(350deg) brightness(95%);
}
.navbar-logo:hover img {
  filter: brightness(1.15) drop-shadow(0 0 8px rgba(255,255,255,0.35));
  transform: scale(1.05);
}
.navbar.white-bg .navbar-logo:hover img {
  filter: brightness(0) saturate(100%) invert(10%) sepia(100%) saturate(6000%) hue-rotate(350deg) brightness(115%) drop-shadow(0 0 6px rgba(180,0,0,0.3));
}

/* ===== Icon buttons ===== */
.icon-btn {
  background: none; border: none; cursor: pointer;
  /* fluid padding using viewport units */
  padding: clamp(0.35rem, 1vw, 0.65rem);
  transition: color 0.25s, transform 0.25s, background 0.25s;
  position: relative;
  display: flex; align-items: center; justify-content: center;
  text-decoration: none;
  border-radius: 50%;
  /* default: transparent navbar → white icons */
  color: rgba(255,255,255,0.85);
}
.icon-btn:hover {
  color: #fff;
  transform: scale(1.12);
  background: rgba(255,255,255,0.08);
}

/* fluid icon size: grows with viewport */
.icon-btn svg {
  width:  clamp(1.1rem, 2.5vw, 1.6rem);
  height: clamp(1.1rem, 2.5vw, 1.6rem);
  display: block;
}

/* ── White-bg state: icons become red ── */
.navbar.white-bg .icon-btn {
  color: rgba(180,0,0,0.85);
}
.navbar.white-bg .icon-btn:hover {
  color: #cc0000;
  background: rgba(180,0,0,0.07);
}

/* ── Scrolled (dark) state: icons white ── */
.navbar.scrolled .icon-btn {
  color: rgba(255,255,255,0.85);
}
.navbar.scrolled .icon-btn:hover {
  color: #fff;
  background: rgba(255,255,255,0.08);
}

/* Cart badge */
.cart-count {
  position: absolute;
  top: clamp(0rem, 0.3vw, 0.1rem);
  right: clamp(0rem, 0.3vw, 0.1rem);
  width:  clamp(0.85rem, 1.8vw, 1.1rem);
  height: clamp(0.85rem, 1.8vw, 1.1rem);
  background: var(--color-accent, #e5c07b);
  color: var(--color-accent-foreground, #000);
  font-size: clamp(0.45rem, 1vw, 0.6rem);
  display: flex; align-items: center; justify-content: center;
  border-radius: 50%; font-weight: 700; line-height: 1;
}

/* Search + Profile — desktop only */
.icon-btn.desktop-only { display: none; }
@media (min-width: 1024px) { .icon-btn.desktop-only { display: flex; } }

/* ===== Sidebar backdrop ===== */
.sidebar-backdrop {
  position: fixed; inset: 0; z-index: 60;
  background: rgba(0,0,0,0.55);
  backdrop-filter: blur(3px);
  opacity: 0; pointer-events: none;
  transition: opacity 0.4s ease;
}
.sidebar-backdrop.open { opacity: 1; pointer-events: auto; }

/* ===== Sidebar ===== */
.sidebar {
  position: fixed; top: 0; left: 0; bottom: 0;
  z-index: 70;
  width: min(22rem, 88vw);
  background: #0a0a0a;
  display: flex; flex-direction: column;
  transform: translateX(-100%);
  transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  overflow-y: auto;
}
.sidebar.open { transform: translateX(0); }

.sidebar-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.4rem 1.5rem 1.2rem;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
.sidebar-header-logo img { height: 1.8rem; }
.sidebar-close {
  background: none; border: none; cursor: pointer;
  color: rgba(255,255,255,0.6); padding: 0.4rem;
  transition: color 0.2s, transform 0.3s;
  display: flex; align-items: center;
}
.sidebar-close:hover { color: #fff; transform: rotate(90deg); }
.sidebar-close svg { width: 1.1rem; height: 1.1rem; }

.sidebar-section-label {
  font-size: 0.6rem; letter-spacing: 0.25em;
  text-transform: uppercase; color: rgba(255,255,255,0.35);
  padding: 1.4rem 1.5rem 0.5rem; font-weight: 700;
}

.sidebar-link {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0.85rem 1.5rem;
  font-size: 0.85rem; letter-spacing: 0.12em;
  text-transform: uppercase; color: rgba(255,255,255,0.75);
  text-decoration: none; border-left: 2px solid transparent;
  font-weight: 600;
  transition: color 0.25s, border-color 0.25s, background 0.25s, padding-left 0.25s,
              opacity 0.35s ease, transform 0.35s ease;
}
.sidebar-link:hover {
  color: #fff;
  border-left-color: var(--color-accent, #e5c07b);
  background: rgba(255,255,255,0.04);
  padding-left: 1.8rem;
}
.sidebar-link svg { width: 0.85rem; height: 0.85rem; opacity: 0.4; }

.sidebar-track-btn {
  margin: 1.4rem 1.5rem;
  display: flex; align-items: center; justify-content: center; gap: 0.6rem;
  padding: 0.9rem 1rem;
  background: transparent;
  border: 1.5px solid rgba(255,255,255,0.25);
  color: rgba(255,255,255,0.8);
  font-size: 0.75rem; font-weight: 700;
  letter-spacing: 0.15em; text-transform: uppercase;
  text-decoration: none; cursor: pointer; font-family: inherit;
  transition: background 0.25s, border-color 0.25s, color 0.25s,
              opacity 0.35s ease, transform 0.35s ease;
}
.sidebar-track-btn:hover {
  background: rgba(255,255,255,0.06);
  border-color: rgba(255,255,255,0.6);
  color: #fff;
}
.sidebar-track-btn svg { width: 0.9rem; height: 0.9rem; flex-shrink: 0; }

.sidebar-divider {
  border: none; border-top: 1px solid rgba(255,255,255,0.07); margin: 0 1.5rem;
}

/* Stagger animation */
.sidebar-link, .sidebar-track-btn {
  opacity: 0; transform: translateX(-16px);
}
.sidebar.open .sidebar-link,
.sidebar.open .sidebar-track-btn { opacity: 1; transform: translateX(0); }
.sidebar.open .sidebar-link:nth-child(1)  { transition-delay: 0.08s; }
.sidebar.open .sidebar-link:nth-child(2)  { transition-delay: 0.13s; }
.sidebar.open .sidebar-link:nth-child(3)  { transition-delay: 0.18s; }
.sidebar.open .sidebar-link:nth-child(4)  { transition-delay: 0.23s; }
.sidebar.open .sidebar-link:nth-child(5)  { transition-delay: 0.28s; }
.sidebar.open .sidebar-link:nth-child(6)  { transition-delay: 0.33s; }
.sidebar.open .sidebar-track-btn          { transition-delay: 0.38s; }

/* ===== Search bar (desktop) ===== */
.navbar-search-bar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 45;
  background: #fff;
  border-bottom: 2px solid #000;
  padding: 0 2rem;
  display: flex; align-items: center; gap: 1rem;
  height: 0; overflow: hidden;
  transition: height 0.35s cubic-bezier(0.22, 1, 0.36, 1);
}
.navbar-search-bar.open {
  height: clamp(3.5rem, 8vh, 5rem);
}
.navbar-search-input {
  flex: 1; border: none; outline: none;
  font-size: clamp(0.9rem, 2vw, 1.2rem);
  font-family: inherit; background: transparent; color: #000;
}
.navbar-search-input::placeholder { color: #aaa; }
.navbar-search-close {
  background: none; border: none; cursor: pointer;
  color: #000; display: flex; align-items: center;
  transition: transform 0.3s;
}
.navbar-search-close:hover { transform: rotate(90deg); }
.navbar-search-close svg {
  width: clamp(1rem, 2vw, 1.4rem);
  height: clamp(1rem, 2vw, 1.4rem);
}
{%- endstyle -%}

<!-- Sidebar backdrop -->
<div class="sidebar-backdrop" id="sidebarBackdrop"></div>

