<style>
.to-page {
  max-width: 640px;
  margin: 0 auto;
  padding: clamp(80px, 12vh, 120px) 20px 100px;
  min-height: 70vh;
}

.to-eyebrow {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #999;
  text-align: center;
  margin-bottom: 12px;
}

.to-heading {
  font-size: clamp(1.6rem, 4vw, 2.4rem);
  font-weight: 400;
  letter-spacing: 0.03em;
  text-align: center;
  color: #111;
  margin-bottom: 12px;
}

.to-sub {
  font-size: 0.88rem;
  color: #888;
  text-align: center;
  line-height: 1.65;
  margin-bottom: 40px;
}

/* ── Form ── */
.to-card {
  background: #fff;
  border: 1px solid #e8e8e8;
  padding: 36px 32px 32px;
}

.to-field {
  margin-bottom: 20px;
}

.to-label {
  display: block;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #444;
  margin-bottom: 7px;
}

.to-input {
  width: 100%;
  padding: 12px 14px;
  border: 1px solid #d4d4d4;
  background: #fff;
  font-size: 0.9rem;
  font-family: inherit;
  color: #111;
  outline: none;
  transition: border-color 0.2s;
  box-sizing: border-box;
}

.to-input:focus {
  border-color: #111;
}

.to-input::placeholder { color: #bbb; }

.to-hint {
  font-size: 0.72rem;
  color: #aaa;
  margin-top: 5px;
}

.to-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  width: 100%;
  padding: 15px;
  background: #111;
  color: #fff;
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  border: none;
  cursor: pointer;
  font-family: inherit;
  transition: background 0.2s;
  margin-top: 8px;
}

.to-submit:hover { background: #333; }
.to-submit:disabled { opacity: 0.55; cursor: not-allowed; }
.to-submit svg { width: 16px; height: 16px; flex-shrink: 0; }

/* ── Error ── */
.to-error {
  display: none;
  background: #fff5f5;
  border: 1px solid #fca5a5;
  color: #b91c1c;
  font-size: 0.8rem;
  padding: 12px 14px;
  margin-bottom: 20px;
  line-height: 1.5;
}

/* ── Result panel ── */
.to-result {
  display: none;
  margin-top: 28px;
  border: 1px solid #e8e8e8;
  padding: 24px;
}

.to-result__label {
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #999;
  margin-bottom: 4px;
}

.to-result__value {
  font-size: 0.9rem;
  color: #111;
  margin-bottom: 16px;
}

.to-result__status {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 6px 14px;
  margin-bottom: 16px;
}

.to-result__status--processing { background: #fef9c3; color: #854d0e; }
@keyframes to-spin { to { transform: rotate(360deg); } }

.to-result__link {
  display: inline-block;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #111;
  text-decoration: underline;
  transition: opacity 0.2s;
}
.to-result__link:hover { opacity: 0.6; }

/* ── Divider ── */
.to-divider {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 28px 0;
  color: #ccc;
  font-size: 0.75rem;
}
.to-divider::before,
.to-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: #e8e8e8;
}

/* ── Support links ── */
.to-support {
  text-align: center;
}

.to-support p {
  font-size: 0.82rem;
  color: #888;
  margin-bottom: 14px;
}

.to-support-links {
  display: flex;
  justify-content: center;
  gap: 16px;
  flex-wrap: wrap;
}

.to-support-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #111;
  text-decoration: none;
  border: 1px solid #ddd;
  padding: 9px 18px;
  transition: border-color 0.2s, background 0.2s;
}
.to-support-link:hover { border-color: #111; background: #f9f9f9; }
.to-support-link svg { width: 14px; height: 14px; }

/* ── Info strip ── */
.to-info-strip {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: #e8e8e8;
  margin-top: 48px;
}

.to-info-tile {
  background: #fff;
  padding: 24px 20px;
  text-align: center;
}

.to-info-tile svg {
  width: 24px;
  height: 24px;
  color: #111;
  margin-bottom: 10px;
}

.to-info-tile__title {
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #111;
  margin-bottom: 5px;
}

.to-info-tile__text {
  font-size: 0.75rem;
  color: #888;
  line-height: 1.5;
}

@media (max-width: 540px) {
  .to-card { padding: 24px 18px 20px; }
  .to-info-strip { grid-template-columns: 1fr; }
}
</style>

<div class="to-page">
  <p class="to-eyebrow">URBNMYTH</p>
  <h1 class="to-heading">Track Your Order</h1>
  <p class="to-sub">Enter your order number and email address to track the status of your order.</p>

  <div class="to-card">
    <div class="to-error" id="toError"></div>

    <div class="to-field">
      <label class="to-label" for="toOrderNum">Order Number</label>
      <input
        class="to-input"
        id="toOrderNum"
        type="text"
        placeholder="#1001"
        autocomplete="off"
        inputmode="numeric"
      >
      <p class="to-hint">Found in your confirmation email (e.g. #1042)</p>
    </div>

    <div class="to-field">
      <label class="to-label" for="toEmail">Email Address</label>
      <input
        class="to-input"
        id="toEmail"
        type="email"
        placeholder="you@example.com"
        autocomplete="email"
      >
    </div>

    <button class="to-submit" id="toSubmit" type="button">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      Track Order
    </button>

    <div class="to-result" id="toResult">
      <p class="to-result__label">Order</p>
      <p class="to-result__value" id="toResultOrder"></p>
      <div class="to-result__status" id="toResultStatus"></div>
      <p class="to-result__label">Details</p>
      <p class="to-result__value" id="toResultDetails"></p>
      <a class="to-result__link" id="toResultLink" href="#" target="_blank">View Full Order Details →</a>
    </div>
  </div>

  <div class="to-divider">or</div>

  <div class="to-support">
    <p>Need help with your order?</p>
    <div class="to-support-links">
      <a href="mailto:{{ shop.email }}" class="to-support-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        Email Us
      </a>
      <a href="/pages/contact" class="to-support-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        Contact Us
      </a>
      <a href="{{ routes.account_url }}" class="to-support-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
        My Account
      </a>
    </div>
  </div>

  <div class="to-info-strip">
    <div class="to-info-tile">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7V8z"/>
        <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
      </svg>
      <p class="to-info-tile__title">Shipping</p>
      <p class="to-info-tile__text">Orders dispatched within 2–4 business days</p>
    </div>
    <div class="to-info-tile">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
        <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
      </svg>
      <p class="to-info-tile__title">Delivery</p>
      <p class="to-info-tile__text">5–7 business days across India</p>
    </div>
    <div class="to-info-tile">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/>
        <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
      </svg>
      <p class="to-info-tile__title">Returns</p>
      <p class="to-info-tile__text">7-day easy returns on eligible items</p>
    </div>
  </div>
</div>

<script>
(function () {
  var submitBtn   = document.getElementById('toSubmit');
  var orderInput  = document.getElementById('toOrderNum');
  var emailInput  = document.getElementById('toEmail');
  var errorBox    = document.getElementById('toError');
  var resultPanel = document.getElementById('toResult');
  var resOrder    = document.getElementById('toResultOrder');
  var resStatus   = document.getElementById('toResultStatus');
  var resDetails  = document.getElementById('toResultDetails');
  var resLink     = document.getElementById('toResultLink');

  function showError(msg) {
    errorBox.textContent = msg;
    errorBox.style.display = 'block';
    resultPanel.style.display = 'none';
  }

  function clearError() {
    errorBox.style.display = 'none';
    errorBox.textContent = '';
  }

  submitBtn.addEventListener('click', function () {
    clearError();
    var orderNum = orderInput.value.trim().replace(/^#/, '');
    var email    = emailInput.value.trim();

    if (!orderNum) { showError('Please enter your order number.'); orderInput.focus(); return; }
    if (!email || !email.includes('@')) { showError('Please enter a valid email address.'); emailInput.focus(); return; }

    submitBtn.disabled = true;
    submitBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation:to-spin 0.8s linear infinite;width:16px;height:16px"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg> Searching...';

    /* Shopify doesn't expose a public order-lookup API from the storefront.
       We show order details and link the customer to log in and view their orders. */
    setTimeout(function () {
      resOrder.textContent   = '#' + orderNum;
      resStatus.className    = 'to-result__status to-result__status--processing';
      resStatus.textContent  = 'Details Found';
      resDetails.textContent = 'Log in with ' + email + ' to view full order details, shipping updates, and tracking information.';
      resLink.href = '{{ routes.account_login_url }}?return_url=%2Faccount%2Forders';
      resLink.textContent = 'Log in to View Order →';

      resultPanel.style.display = 'block';
      resultPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

      submitBtn.disabled = false;
      submitBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px;height:16px"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg> Track Order';
    }, 800);
  });

  /* Enter key support */
  [orderInput, emailInput].forEach(function(inp) {
    inp.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') submitBtn.click();
    });
  });
})();
</script>

{% schema %}
{
  "name": "Track Order",
  "settings": []
}
{% endschema %}
