<script
  src="{{ 'results-list.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{% javascript %}
  const url = new URL(window.location.href);
  if (url.hash) {
    document.addEventListener(
      'DOMContentLoaded',
      () => {
        const card = document.getElementById(url.hash.slice(1));
        if (card) {
          card.scrollIntoView({ behavior: 'instant' });
        }
      },
      { once: true }
    );
  }
{% endjavascript %}

<div class="col-wrap">
  <div class="col-inner">

    <!-- Breadcrumb -->
    <nav class="col-bc" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/collections">Collections</a>
      <span aria-hidden="true">/</span>
      <span>{{ collection.title }}</span>
    </nav>

    <!-- Collection Header -->
    <div class="col-hdr">
      <h1 class="col-hdr__title">{{ collection.title }}</h1>
      <span class="col-hdr__count">{{ collection.products_count }} Products</span>
    </div>

    <!-- Filter + Sort Bar -->
    <div class="col-bar">

      <!-- Filter pills -->
      {% if section.settings.show_filter_pills %}
        <div class="col-pills" id="col-pills">
          <a href="{{ collection.url }}"
             class="col-pill{% unless current_tags %}  col-pill--on{% endunless %}">All</a>
          {% for tag in collection.all_tags %}
            {% if current_tags contains tag %}
              <a href="{{ collection.url }}" class="col-pill col-pill--on">{{ tag }}</a>
            {% else %}
              <a href="/collections/{{ collection.handle }}/{{ tag | handle }}" class="col-pill">{{ tag }}</a>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}

      <!-- Right: sort + column toggles -->
      <div class="col-bar__right">
        <div class="col-sort-wrap">
          <select class="col-sort" onchange="colSort(this.value)">
            <option value="manual"             {% if collection.sort_by == 'manual' %}selected{% endif %}>Featured</option>
            <option value="best-selling"       {% if collection.sort_by == 'best-selling' %}selected{% endif %}>Best Selling</option>
            <option value="created-descending" {% if collection.sort_by == 'created-descending' %}selected{% endif %}>Newest</option>
            <option value="created-ascending"  {% if collection.sort_by == 'created-ascending' %}selected{% endif %}>Oldest</option>
            <option value="price-ascending"    {% if collection.sort_by == 'price-ascending' %}selected{% endif %}>Price: Low → High</option>
            <option value="price-descending"   {% if collection.sort_by == 'price-descending' %}selected{% endif %}>Price: High → Low</option>
            <option value="title-ascending"    {% if collection.sort_by == 'title-ascending' %}selected{% endif %}>A → Z</option>
            <option value="title-descending"   {% if collection.sort_by == 'title-descending' %}selected{% endif %}>Z → A</option>
          </select>
          <svg class="col-sort-caret" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
        </div>

        <div class="col-view-btns">
          <button class="col-view-btn" data-cols="2" onclick="colSetCols(2, this)" title="2 columns">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="2" width="9" height="20" rx="1"/><rect x="13" y="2" width="9" height="20" rx="1"/>
            </svg>
          </button>
          <button class="col-view-btn on" data-cols="3" onclick="colSetCols(3, this)" title="3 columns">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2" y="2" width="5" height="20" rx="1"/><rect x="9.5" y="2" width="5" height="20" rx="1"/><rect x="17" y="2" width="5" height="20" rx="1"/>
            </svg>
          </button>
          <button class="col-view-btn" data-cols="4" onclick="colSetCols(4, this)" title="4 columns">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="2"  y="2" width="4" height="20" rx="1"/>
              <rect x="8"  y="2" width="4" height="20" rx="1"/>
              <rect x="14" y="2" width="4" height="20" rx="1"/>
              <rect x="20" y="2" width="4" height="20" rx="1"/>
            </svg>
          </button>
        </div>
      </div>

    </div><!-- /col-bar -->

    <!-- Products Grid -->
    {% paginate collection.products by 24 %}

      <div class="col-grid col-g3" id="col-grid">

        {% assign display_products = collection.products %}
        {% assign is_filtered = false %}

        {% for filter in collection.filters %}
          {% if filter.active_values.size > 0 %}
            {% assign is_filtered = true %}
            {% break %}
          {% endif %}
        {% endfor %}

        {% if display_products.size == 0 and is_filtered == false %}
          {% assign display_products = collections.all.products %}
        {% endif %}

        {% for product in display_products %}
          {% render 'card-product-urbnmyth', product: product %}
        {% else %}
          <div class="col-empty" style="grid-column: 1 / -1;">
            <div class="col-empty__content">
              <div class="col-empty__icon">
                <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                  <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                </svg>
              </div>
              {% if is_filtered %}
                <h3 class="col-empty__title">No Products Found</h3>
                <p class="col-empty__sub">Try adjusting your filters or browse all products.</p>
                <button onclick="clearAllFilters()" class="col-empty__btn">Clear All Filters</button>
              {% else %}
                <h3 class="col-empty__title">Coming Soon</h3>
                <p class="col-empty__sub">Fresh drops are on the way. Stay tuned for new arrivals.</p>
                <a href="/collections/all" class="col-empty__btn">Browse Collection</a>
              {% endif %}
            </div>
          </div>
        {% endfor %}

      </div><!-- /col-grid -->

      <!-- Pagination -->
      {% if paginate.pages > 1 %}
        <div class="col-pagination">
          {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}" class="col-pagination__btn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
              Prev
            </a>
          {% endif %}
          {% for part in paginate.parts %}
            {% if part.is_link %}
              <a href="{{ part.url }}" class="col-pagination__btn">{{ part.title }}</a>
            {% else %}
              <span class="col-pagination__current">{{ part.title }}</span>
            {% endif %}
          {% endfor %}
          {% if paginate.next %}
            <a href="{{ paginate.next.url }}" class="col-pagination__btn">
              Next
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          {% endif %}
        </div>
      {% endif %}

    {% endpaginate %}

    {% render 'founder-story-whatsapp' %}

    <!-- Collection Description -->
    {% if collection.description != blank %}
      <div class="col-desc">
        {{ collection.description }}
      </div>
    {% endif %}

  </div><!-- /col-inner -->
</div><!-- /col-wrap -->

<style>
/* ─── Page Wrapper ──────────────────────────────────────── */
.col-wrap {
  background: #fff;
  min-height: 100dvh;
  /* top padding = fixed navbar height, matches navbar.liquid clamp values */
  padding: clamp(3.5rem, 8vh, 5rem) 20px 60px;
  font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}
@media (min-width: 640px)  { .col-wrap { padding-top: clamp(4rem, 9vh, 5.5rem);  } }
@media (min-width: 1024px) { .col-wrap { padding-top: clamp(4.5rem, 10vh, 6rem); } }
.col-inner {
  max-width: 1400px;
  margin: 0 auto;
}

/* ─── Breadcrumb ────────────────────────────────────────── */
.col-bc {
  font-size: 0.75rem;
  color: #888;
  margin: 16px 0 24px;
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  align-items: center;
}
.col-bc a {
  color: inherit;
  text-decoration: none;
}
.col-bc a:hover { color: #111; }
.col-bc span { color: #111; }

/* ─── Collection Header ─────────────────────────────────── */
.col-hdr {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20px;
  padding-bottom: 16px;
  border-bottom: 1px solid #e8e8e8;
}
.col-hdr__title {
  font-size: clamp(1.6rem, 4vw, 2.4rem);
  font-weight: 400;
  letter-spacing: 0.02em;
  margin: 0;
}
.col-hdr__count {
  font-size: 0.8rem;
  color: #999;
}

/* ─── Filter + Sort Bar ─────────────────────────────────── */
.col-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 28px;
  flex-wrap: wrap;
}
.col-pills {
  display: flex;
  gap: 8px;
  flex-wrap: nowrap;
  overflow-x: auto;
  flex: 1;
  scrollbar-width: none;
}
.col-pills::-webkit-scrollbar { display: none; }

.col-pill {
  display: inline-block;
  padding: 7px 16px;
  border: 1px solid #ddd;
  font-size: 0.78rem;
  text-decoration: none;
  color: #555;
  white-space: nowrap;
  border-radius: 0;
  transition: background 0.2s, color 0.2s, border-color 0.2s;
}
.col-pill--on {
  background: #111;
  color: #fff;
  border-color: #111;
}
.col-pill:hover:not(.col-pill--on) {
  border-color: #999;
  color: #111;
}

.col-bar__right {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-shrink: 0;
}
.col-sort-wrap {
  position: relative;
  display: flex;
  align-items: center;
}
.col-sort {
  appearance: none;
  background: #fff;
  border: 1px solid #ddd;
  padding: 8px 32px 8px 12px;
  font-size: 0.78rem;
  color: #333;
  cursor: pointer;
  font-family: inherit;
  outline: none;
}
.col-sort:hover { border-color: #999; }
.col-sort-caret {
  position: absolute;
  right: 10px;
  pointer-events: none;
  color: #555;
}
.col-view-btns {
  display: flex;
  gap: 3px;
}
.col-view-btn {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border: 1px solid #ddd;
  cursor: pointer;
  color: #aaa;
  transition: all 0.15s;
}
.col-view-btn:hover {
  border-color: #999;
  color: #555;
}
.col-view-btn.on {
  background: #111;
  border-color: #111;
  color: #fff;
}

/* ─── Grid ──────────────────────────────────────────────── */
.col-grid {
  display: grid;
  gap: 20px;
  transition: gap 0.3s;
}
.col-g2 { grid-template-columns: repeat(2, 1fr); }
.col-g3 { grid-template-columns: repeat(3, 1fr); }
.col-g4 { grid-template-columns: repeat(4, 1fr); }

/* ─── Product Card ──────────────────────────────────────── */
.urbnmyth-product-card {
  background: #fff;
  position: relative;
}

/* ─── Product Image ─────────────────────────────────────── */
.urbnmyth-product-image {
  display: block;
  position: relative;
  width: 100%;
  aspect-ratio: 3 / 4;
  overflow: hidden;
  background: #eeebe7;
}
.urbnmyth-img-primary,
.urbnmyth-img-secondary {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: opacity 0.6s ease;
}
.urbnmyth-img-primary  { opacity: 1; z-index: 1; }
.urbnmyth-img-secondary { opacity: 0; z-index: 2; }
.urbnmyth-product-placeholder {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  background: #eeebe7; color: #ccc;
}

/* ─── Top-left Badge ─────────────────────────────────────── */
.urbnmyth-badge-tl {
  position: absolute; top: 14px; left: 14px;
  background: #fff; color: #1a1a1a;
  padding: 4px 10px;
  font-size: 0.7rem; font-weight: 400;
  letter-spacing: 0.2px; z-index: 10;
  line-height: 1; white-space: nowrap;
}

/* ─── Right-side Action Buttons ──────────────────────────── */
.urbnmyth-right-actions {
  position: absolute; top: 14px; right: 14px;
  display: flex; flex-direction: column; gap: 10px;
  z-index: 20;
}
.urbnmyth-circle-btn {
  width: 36px; height: 36px;
  border-radius: 50%;
  background: #fff;
  border: none;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; color: #1a1a1a;
  box-shadow: 0 2px 8px rgba(0,0,0,0.12);
  flex-shrink: 0;
  position: relative;
  opacity: 0;
  transform: translateX(14px);
  pointer-events: none;
  transition: opacity 0.3s ease, transform 0.3s ease, background 0.2s ease;
}
.urbnmyth-product-card:hover .urbnmyth-circle-btn {
  pointer-events: auto;
}
.urbnmyth-product-card:hover .urbnmyth-circle-btn:nth-child(1) {
  opacity: 1; transform: translateX(0); transition-delay: 0ms;
}
.urbnmyth-product-card:hover .urbnmyth-circle-btn:nth-child(2) {
  opacity: 1; transform: translateX(0); transition-delay: 80ms;
}
.urbnmyth-product-card:hover .urbnmyth-circle-btn:nth-child(3) {
  opacity: 1; transform: translateX(0); transition-delay: 160ms;
}
.urbnmyth-circle-btn:hover { background: #f2f2f2; transform: translateX(0) scale(1.07); }
.urbnmyth-wishlist-btn.urbnmyth-wishlisted svg { fill: #1a1a1a; }

/* Tooltip */
.urbnmyth-circle-btn::before {
  content: attr(data-tooltip);
  position: absolute;
  right: calc(100% + 10px);
  top: 50%; transform: translateY(-50%);
  background: #1a1a1a; color: #fff;
  padding: 4px 9px;
  font-size: 0.68rem; font-weight: 400;
  letter-spacing: 0.3px; white-space: nowrap;
  opacity: 0; pointer-events: none;
  transition: opacity 0.15s ease;
  font-family: inherit;
}
.urbnmyth-circle-btn:hover::before { opacity: 1; }

/* ─── Add To Cart bar ────────────────────────────────────── */
.urbnmyth-hover-add {
  position: absolute; bottom: 0; left: 0; right: 0;
  z-index: 15; transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  border-top: 1px solid rgba(0,0,0,0.07);
}
.urbnmyth-product-card:hover .urbnmyth-hover-add { transform: translateY(0); }
.urbnmyth-hover-add-btn {
  width: 100%; padding: 16px 20px;
  background: #fff; color: #1a1a1a; border: none;
  font-size: 0.85rem; font-weight: 400;
  cursor: pointer; letter-spacing: 0.2px;
  display: flex; align-items: center; justify-content: center;
  font-family: inherit; transition: background 0.2s ease;
}
.urbnmyth-hover-add-btn:hover:not(:disabled) { background: #f5f5f5; }
.urbnmyth-hover-add-btn:disabled { background: #f0f0f0; color: #aaa; cursor: not-allowed; }

/* ─── Product Info ──────────────────────────────────────── */
.urbnmyth-product-info { padding: 12px 2px 18px; }
.urbnmyth-product-title {
  display: block; font-size: 0.88rem; font-weight: 400;
  margin-bottom: 5px;
  text-decoration: none; color: #1a1a1a; line-height: 1.45;
  letter-spacing: 0.05px; transition: opacity 0.2s;
}
.urbnmyth-product-title:hover { opacity: 0.6; }
.urbnmyth-product-price {
  display: flex; align-items: center; gap: 8px;
  margin-bottom: 10px; font-weight: 400; font-size: 0.88rem; flex-wrap: wrap;
  color: #1a1a1a;
}
.urbnmyth-price-sale    { color: #1a1a1a; }
.urbnmyth-price-compare { font-size: 0.82rem; color: #999; text-decoration: line-through; }
.urbnmyth-price-regular { color: #1a1a1a; }

/* ─── Size Chips ──────────────────────────────────────────── */
.urbnmyth-sizes { display: flex; flex-wrap: wrap; gap: 5px; }
.urbnmyth-size-chip {
  display: inline-flex; align-items: center; justify-content: center;
  min-width: 32px; padding: 4px 8px;
  font-size: 0.68rem; font-weight: 400;
  letter-spacing: 0.2px; text-transform: uppercase;
  border: 1px solid #1a1a1a; color: #1a1a1a; background: #fff;
  line-height: 1; cursor: pointer; font-family: inherit;
  transition: background 0.18s ease, color 0.18s ease;
}
.urbnmyth-size-chip:hover { background: #1a1a1a; color: #fff; }
.urbnmyth-size-chip.urbnmyth-size-selected { background: #1a1a1a; color: #fff; }
.urbnmyth-size-chip.urbnmyth-size-sold { border-color: #ddd; color: #bbb; cursor: default; }

/* ─── Color Swatches ─────────────────────────────────────── */
.urbnmyth-color-swatches {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  margin-top: 8px;
}
.urbnmyth-color-dot {
  display: inline-block;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  border: 1px solid rgba(0,0,0,0.15);
  cursor: pointer;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}
.urbnmyth-color-dot:hover {
  transform: scale(1.2);
  box-shadow: 0 0 0 2px #fff, 0 0 0 3px #111;
}

/* ─── Collection Description ─────────────────────────────── */
.col-desc {
  max-width: 720px;
  margin: 60px auto 0;
  padding: 40px 0;
  border-top: 1px solid #e8e8e8;
  font-size: 0.9rem;
  line-height: 1.8;
  color: #555;
  text-align: center;
}

/* ─── Empty State ───────────────────────────────────────── */
.col-empty { text-align: center; padding: 80px 20px; }
.col-empty__content { max-width: 460px; margin: 0 auto; }
.col-empty__icon { margin-bottom: 28px; color: #ddd; }
.col-empty__title {
  font-size: 1.5rem; font-weight: 400; letter-spacing: 0.02em;
  margin-bottom: 12px; color: #111;
}
.col-empty__sub { font-size: 0.95rem; color: #888; margin-bottom: 28px; line-height: 1.6; }
.col-empty__btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 13px 28px; background: #111; color: #fff;
  text-decoration: none; font-size: 0.82rem; letter-spacing: 0.05em;
  border: 1px solid #111; cursor: pointer; font-family: inherit;
  transition: background 0.2s, color 0.2s;
}
.col-empty__btn:hover { background: #fff; color: #111; }

/* ─── Pagination ────────────────────────────────────────── */
.col-pagination {
  display: flex; justify-content: center; align-items: center;
  gap: 6px; margin-top: 60px; padding-top: 40px;
  border-top: 1px solid #e8e8e8; flex-wrap: wrap;
}
.col-pagination__btn {
  display: flex; align-items: center; gap: 6px;
  padding: 9px 16px; background: #fff; color: #333;
  border: 1px solid #ddd; text-decoration: none;
  font-size: 0.82rem; transition: all 0.2s;
}
.col-pagination__btn:hover { border-color: #111; color: #111; }
.col-pagination__current {
  padding: 9px 16px; background: #111; color: #fff;
  border: 1px solid #111; font-size: 0.82rem;
}

/* ─── Responsive ────────────────────────────────────────── */

/* Large desktop: allow 4-col to stay 3-col */
@media (max-width: 1100px) {
  .col-g4 { grid-template-columns: repeat(3, 1fr); }
}

/* Tablet: cap at 2 cols */
@media (max-width: 900px) {
  .col-g3,
  .col-g4 { grid-template-columns: repeat(2, 1fr); }
}

/* ── Mobile landscape / large phone (≤768px) ── */
@media (max-width: 768px) {
  .col-wrap { padding-left: 12px; padding-right: 12px; padding-bottom: 40px; }

  /* Filter bar: pills scroll, sort stays right */
  .col-bar { gap: 10px; flex-wrap: nowrap; align-items: center; }
  .col-pills { overflow-x: auto; flex: 1; }

  /* Hide column toggles — always 2 cols on mobile */
  .col-view-btns { display: none; }

  /* Lock all col variants to 2 */
  .col-g2, .col-g3, .col-g4 { grid-template-columns: repeat(2, 1fr); }
  .col-grid { gap: 12px; }

  /* Action buttons: always visible (no hover state needed) */
  .urbnmyth-circle-btn {
    opacity: 1;
    transform: none;
    pointer-events: auto;
    width: 30px;
    height: 30px;
  }
  .urbnmyth-circle-btn:nth-child(1),
  .urbnmyth-circle-btn:nth-child(2),
  .urbnmyth-circle-btn:nth-child(3) { transition-delay: 0ms; }
  .urbnmyth-right-actions { top: 8px; right: 8px; gap: 6px; }
  .urbnmyth-badge-tl { top: 8px; left: 8px; font-size: 0.62rem; padding: 3px 7px; }
  .urbnmyth-circle-btn::before { display: none; } /* no tooltips on touch */

  /* Add-to-cart bar always visible */
  .urbnmyth-hover-add { transform: none; }
  .urbnmyth-hover-add-btn { padding: 11px 12px; font-size: 0.76rem; }

  .urbnmyth-product-info { padding: 8px 1px 12px; }
}

/* ── Standard mobile portrait (≤480px) ── */
@media (max-width: 480px) {
  .col-wrap { padding-left: 10px; padding-right: 10px; padding-bottom: 32px; }
  .col-grid { gap: 10px; }

  .col-hdr { margin-bottom: 14px; padding-bottom: 10px; }
  .col-hdr__title { font-size: clamp(1.25rem, 5vw, 1.5rem); }
  .col-hdr__count { font-size: 0.72rem; }

  .col-bc { font-size: 0.68rem; margin: 10px 0 14px; gap: 4px; }

  .col-pill { font-size: 0.7rem; padding: 5px 11px; }
  .col-sort { font-size: 0.7rem; padding: 6px 26px 6px 10px; }

  .urbnmyth-product-title { font-size: 0.76rem; }
  .urbnmyth-product-price { font-size: 0.76rem; margin-bottom: 6px; }
  .urbnmyth-price-compare { font-size: 0.7rem; }

  .urbnmyth-size-chip { font-size: 0.58rem; padding: 3px 5px; min-width: 24px; }
  .urbnmyth-sizes { gap: 4px; }

  .urbnmyth-circle-btn { width: 28px; height: 28px; }
  .urbnmyth-hover-add-btn { padding: 10px; font-size: 0.72rem; }
  .urbnmyth-product-info { padding: 7px 1px 10px; }

  .col-bar { gap: 8px; }
}

/* ── Small phones (≤375px) ── */
@media (max-width: 375px) {
  .col-wrap { padding-left: 8px; padding-right: 8px; }
  .col-grid { gap: 8px; }
  .urbnmyth-product-title { font-size: 0.7rem; }
  .urbnmyth-product-price { font-size: 0.7rem; }
  .urbnmyth-size-chip { font-size: 0.55rem; padding: 2px 4px; min-width: 20px; }
  .urbnmyth-circle-btn { width: 26px; height: 26px; }
}

/* ── Very small / compact phones (≤320px) ── */
@media (max-width: 320px) {
  .col-wrap { padding-left: 6px; padding-right: 6px; }
  .col-grid { gap: 6px; }
  .urbnmyth-product-title { font-size: 0.65rem; }
  .urbnmyth-size-chip { font-size: 0.5rem; padding: 2px 3px; min-width: 18px; }
}
</style>

<script>
/* ── Sort ─────────────────────────────────────────────────── */
function colSort(value) {
  const url = new URL(window.location.href);
  url.searchParams.set('sort_by', value);
  window.location.href = url.toString();
}

/* ── Column toggle ────────────────────────────────────────── */
function colSetCols(n, btn) {
  const grid = document.getElementById('col-grid');
  if (!grid) return;
  grid.className = grid.className.replace(/col-g\d/g, '').trim() + ' col-g' + n;
  document.querySelectorAll('.col-view-btn').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
  try { localStorage.setItem('col_cols', n); } catch(e) {}
}

document.addEventListener('DOMContentLoaded', function () {
  /* restore saved column preference */
  try {
    const saved = localStorage.getItem('col_cols');
    if (saved) {
      const btn = document.querySelector('[data-cols="' + saved + '"]');
      if (btn) colSetCols(Number(saved), btn);
    }
  } catch(e) {}

  /* ── Image swap on hover ────────────────────────────────── */
  document.querySelectorAll('.urbnmyth-product-image').forEach(function (imageWrap) {
    const rawImages = (imageWrap.dataset.images || '').split('||').filter(Boolean);
    if (rawImages.length < 2) return;

    const primary   = imageWrap.querySelector('.urbnmyth-img-primary');
    const secondary = imageWrap.querySelector('.urbnmyth-img-secondary');
    if (!primary || !secondary) return;

    rawImages.forEach(function(src) { const img = new Image(); img.src = src; });

    imageWrap.addEventListener('mouseenter', function () {
      primary.style.opacity   = '0';
      secondary.style.opacity = '1';
    });

    imageWrap.addEventListener('mouseleave', function () {
      primary.style.opacity   = '1';
      secondary.style.opacity = '0';
    });
  });

  /* ── Wishlist state restore ─────────────────────────────── */
  try {
    const wl = JSON.parse(localStorage.getItem('urbnmyth_wishlist') || '[]');
    wl.forEach(function (id) {
      document.querySelectorAll('.urbnmyth-wishlist-btn[data-product-id="' + id + '"]').forEach(function(btn) {
        btn.classList.add('urbnmyth-wishlisted');
      });
    });
  } catch(e) {}
});

/* ── Size selection ───────────────────────────────────────── */
function urbnmythSelectSize(event, btn) {
  event.preventDefault();
  event.stopPropagation();
  const sizeContainer = btn.closest('.urbnmyth-sizes');
  if (sizeContainer) {
    sizeContainer.querySelectorAll('.urbnmyth-size-chip').forEach(function(chip) {
      chip.classList.remove('urbnmyth-size-selected');
    });
  }
  btn.classList.add('urbnmyth-size-selected');
  const card = btn.closest('.urbnmyth-product-card');
  if (card) {
    const quickAddBtn = card.querySelector('.urbnmyth-hover-add-btn');
    if (quickAddBtn && btn.dataset.variantId) {
      quickAddBtn.setAttribute(
        'onclick',
        "urbnmythQuickAddToCart(event, '" + btn.dataset.variantId + "', this)"
      );
    }
  }
}

/* ── Quick Add ────────────────────────────────────────────── */
function urbnmythQuickAddToCart(event, variantId, button) {
  event.preventDefault();
  event.stopPropagation();

  const originalHTML = button.innerHTML;
  button.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg> Adding...';
  button.disabled = true;

  const formData = new FormData();
  formData.append('id', variantId);
  formData.append('quantity', 1);

  fetch('/cart/add.js', { method: 'POST', body: formData })
    .then(r => r.json())
    .then(() => {
      button.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg> Added!';
      setTimeout(() => { window.location.href = '/cart'; }, 600);
    })
    .catch(() => {
      button.innerHTML = 'Error — Try Again';
      button.style.background = '#dc3545';
      button.style.color = '#fff';
      setTimeout(() => {
        button.innerHTML = originalHTML;
        button.disabled = false;
        button.style.background = '';
        button.style.color = '';
      }, 2000);
    });
}

/* ── Manual Image Cycle ───────────────────────────────────── */
function urbnmythManualCycle(event, btn) {
  event.preventDefault();
  event.stopPropagation();
  const imageWrap = btn.closest('.urbnmyth-product-image');
  if (!imageWrap) return;
  const rawImages = (imageWrap.dataset.images || '').split('||').filter(Boolean);
  if (rawImages.length < 2) return;
  const primary   = imageWrap.querySelector('.urbnmyth-img-primary');
  const secondary = imageWrap.querySelector('.urbnmyth-img-secondary');
  if (!primary || !secondary) return;
  let idx = parseInt(imageWrap.dataset.manualIndex || '1', 10);
  idx = (idx + 1) % rawImages.length;
  imageWrap.dataset.manualIndex = idx;
  secondary.src = rawImages[idx];
  primary.style.opacity   = '0';
  secondary.style.opacity = '1';
}

/* ── Quick View ───────────────────────────────────────────── */
function urbnmythQuickView(event, productUrl) {
  event.preventDefault();
  event.stopPropagation();
  window.open(productUrl + '?quickview=1', '_blank', 'noopener');
}

/* ── Wishlist Toggle ──────────────────────────────────────── */
function urbnmythToggleWishlist(event, productId, btn) {
  event.preventDefault();
  event.stopPropagation();
  try {
    let wl = JSON.parse(localStorage.getItem('urbnmyth_wishlist') || '[]');
    const idx = wl.indexOf(String(productId));
    if (idx === -1) {
      wl.push(String(productId));
      btn.classList.add('urbnmyth-wishlisted');
    } else {
      wl.splice(idx, 1);
      btn.classList.remove('urbnmyth-wishlisted');
    }
    localStorage.setItem('urbnmyth_wishlist', JSON.stringify(wl));
  } catch(e) {}
}

/* ── Clear Filters ────────────────────────────────────────── */
function clearAllFilters() {
  const url = new URL(window.location.href);
  const params = new URLSearchParams(url.search);
  [...params.keys()].filter(k => k.startsWith('filter.') || k === 'sort_by')
                    .forEach(k => params.delete(k));
  window.location.href = url.pathname + (params.toString() ? '?' + params.toString() : '');
}
</script>

{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 48,
      "step": 8,
      "label": "Products per page",
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "show_filter_pills",
      "label": "Show filter pills",
      "default": true
    }
  ]
}
