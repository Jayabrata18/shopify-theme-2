    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }

  .lp-cp__view-all:hover {
    background: #111;
    color: #fff;
  }

  /* ── Editorial break ──────────────────────────────── */
  .lp-editorial {
    position: relative;
    overflow: hidden;
    height: clamp(320px, 45vw, 560px);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lp-editorial__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .lp-editorial__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
  }

  .lp-editorial__content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: #fff;
    padding: 0 20px;
  }

  .lp-editorial__eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.7;
    margin-bottom: 10px;
  }

  .lp-editorial__heading {
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0 0 24px;
  }

  .lp-editorial__btn {
    display: inline-block;
    padding: 13px 40px;
    border: 1.5px solid #fff;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }

  .lp-editorial__btn:hover {
    background: #fff;
    color: #111;
  }

  /* ── Product Card (card-product-urbnmyth) ────────── */
  .lp-cp-wrap .urbnmyth-product-card {
    background: #fff;
    position: relative;
  }
  .lp-cp-wrap .urbnmyth-product-image {
    display: block;
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #eeebe7;
  }
  .lp-cp-wrap .urbnmyth-img-primary,
  .lp-cp-wrap .urbnmyth-img-secondary {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.6s ease;
  }
  .lp-cp-wrap .urbnmyth-img-primary {
    opacity: 1;
    z-index: 1;
  }
  .lp-cp-wrap .urbnmyth-img-secondary {
    opacity: 0;
    z-index: 2;
  }
  .lp-cp-wrap .urbnmyth-product-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #eeebe7;
    color: #ccc;
  }
  .lp-cp-wrap .urbnmyth-badge-tl {
    position: absolute;
    top: 14px;
    left: 14px;
    background: #fff;
    color: #1a1a1a;
    padding: 4px 10px;
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.2px;
    z-index: 10;
    line-height: 1;
    white-space: nowrap;
  }
  .lp-cp-wrap .urbnmyth-right-actions {
    position: absolute;
    top: 14px;
    right: 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    z-index: 20;
  }
  .lp-cp-wrap .urbnmyth-circle-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #fff;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #1a1a1a;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
    flex-shrink: 0;
    position: relative;
    opacity: 0;
    transform: translateX(14px);
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s ease, background 0.2s ease;
  }
  .lp-cp-wrap .urbnmyth-product-card:hover .urbnmyth-circle-btn {
    pointer-events: auto;
  }
  .lp-cp-wrap .urbnmyth-product-card:hover .urbnmyth-circle-btn:nth-child(1) {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 0ms;
  }
  .lp-cp-wrap .urbnmyth-product-card:hover .urbnmyth-circle-btn:nth-child(2) {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 80ms;
  }
  .lp-cp-wrap .urbnmyth-product-card:hover .urbnmyth-circle-btn:nth-child(3) {
    opacity: 1;
    transform: translateX(0);
    transition-delay: 160ms;
  }
  .lp-cp-wrap .urbnmyth-circle-btn:hover {
    background: #f2f2f2;
  }
  .lp-cp-wrap .urbnmyth-circle-btn::before {
    content: attr(data-tooltip);
    position: absolute;
    right: calc(100% + 10px);
    top: 50%;
    transform: translateY(-50%);
    background: #1a1a1a;
    color: #fff;
    padding: 4px 9px;
    font-size: 0.68rem;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s ease;
    font-family: inherit;
  }
  .lp-cp-wrap .urbnmyth-circle-btn:hover::before {
    opacity: 1;
  }
  .lp-cp-wrap .urbnmyth-hover-add {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 15;
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    padding: 8px 8px;
  }
  .lp-cp-wrap .urbnmyth-product-card:hover .urbnmyth-hover-add {
    transform: translateY(0);
  }
  .lp-cp-wrap .urbnmyth-hover-add-btn {
    width: 100%;
    padding: 16px 20px;
    background: #fff;
    color: #1a1a1a;
    border: none;
    font-size: 0.85rem;
    font-weight: 400;
    cursor: pointer;
    letter-spacing: 0.2px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: inherit;
    transition: background 0.2s ease;
  }
  .lp-cp-wrap .urbnmyth-hover-add-btn:hover:not(:disabled) {
    background: #f5f5f5;
  }
  .lp-cp-wrap .urbnmyth-hover-add-btn:disabled {
    background: #f0f0f0;
    color: #aaa;
    cursor: not-allowed;
  }
  .lp-cp-wrap .urbnmyth-product-info {
    padding: 12px 2px 18px;
  }
  .lp-cp-wrap .urbnmyth-product-title {
    display: block;
    font-size: 0.88rem;
    font-weight: 400;
    margin-bottom: 5px;
    text-decoration: none;
    color: #1a1a1a;
    line-height: 1.45;
    letter-spacing: 0.05px;
    transition: opacity 0.2s;
  }
  .lp-cp-wrap .urbnmyth-product-title:hover {
    opacity: 0.6;
  }
  .lp-cp-wrap .urbnmyth-product-price {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
    font-weight: 400;
    font-size: 0.88rem;
    flex-wrap: wrap;
    color: #1a1a1a;
  }
  .lp-cp-wrap .urbnmyth-price-sale {
    color: #1a1a1a;
  }
  .lp-cp-wrap .urbnmyth-price-compare {
    font-size: 0.82rem;
    color: #999;
    text-decoration: line-through;
  }
  .lp-cp-wrap .urbnmyth-price-regular {
    color: #1a1a1a;
  }
  .lp-cp-wrap .urbnmyth-sizes {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }
  .lp-cp-wrap .urbnmyth-size-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 32px;
    padding: 4px 8px;
    font-size: 0.68rem;
    font-weight: 400;
    letter-spacing: 0.2px;
    text-transform: uppercase;
    border: 1px solid #1a1a1a;
    color: #1a1a1a;
    background: #fff;
    line-height: 1;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.18s ease, color 0.18s ease;
  }
  .lp-cp-wrap .urbnmyth-size-chip:hover,
  .lp-cp-wrap .urbnmyth-size-chip.urbnmyth-size-selected {
    background: #1a1a1a;
    color: #fff;
  }
  .lp-cp-wrap .urbnmyth-size-chip.urbnmyth-size-sold {
    border-color: #ddd;
    color: #bbb;
    cursor: default;
  }
  .lp-cp-wrap .urbnmyth-color-swatches {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-top: 8px;
  }
  .lp-cp-wrap .urbnmyth-color-dot {
    display: inline-block;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.15);
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
