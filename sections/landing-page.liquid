<!-- ═══════════════════════════════════════════════════
     HERO SECTION
═══════════════════════════════════════════════════ -->
<section class="lp-hero" id="lp-hero">
  {%- assign hero_bg = section.settings.hero_image | image_url: width: 2000 -%}
  {%- if section.settings.hero_youtube_id != blank -%}
    <div class="lp-hero__video-wrap">
      <iframe
        class="lp-hero__iframe"
        src="https://www.youtube.com/embed/{{ section.settings.hero_youtube_id }}?autoplay=1&mute=1&loop=1&playlist={{ section.settings.hero_youtube_id }}&controls=0&showinfo=0&rel=0&modestbranding=1"
        frameborder="0"
        allow="autoplay; fullscreen"
        allowfullscreen
      ></iframe>
      <div class="lp-hero__overlay"></div>
    </div>
  {%- elsif section.settings.hero_image != blank -%}
    <div class="lp-hero__img-wrap">
      <img
        src="{{ hero_bg }}"
        alt="{{ section.settings.hero_heading | escape }}"
        class="lp-hero__img lp-hero__img--kenburns"
        loading="eager"
      >
      <div class="lp-hero__overlay"></div>
    </div>
  {%- else -%}
    <div class="lp-hero__img-wrap">
      <img
        src="https://images.unsplash.com/photo-1523398002811-999ca8dec234?w=2000&q=80&fit=crop"
        alt="Hero"
        class="lp-hero__img lp-hero__img--kenburns"
        loading="eager"
      >
      <div class="lp-hero__overlay"></div>
    </div>
  {%- endif -%}

  <div class="lp-hero__content">
    {%- if section.settings.hero_eyebrow != blank -%}
      <p class="lp-hero__eyebrow">{{ section.settings.hero_eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.hero_heading != blank -%}
      <h1 class="lp-hero__heading">{{ section.settings.hero_heading }}</h1>
    {%- endif -%}
    {%- if section.settings.hero_subheading != blank -%}
      <p class="lp-hero__subheading">{{ section.settings.hero_subheading }}</p>
    {%- endif -%}
    <div class="lp-hero__btns">
      {%- if section.settings.hero_btn1_text != blank -%}
        <a href="{{ section.settings.hero_btn1_link }}" class="lp-btn lp-btn--primary">
          {{ section.settings.hero_btn1_text }}
        </a>
      {%- endif -%}
      {%- if section.settings.hero_btn2_text != blank -%}
        <a href="{{ section.settings.hero_btn2_link }}" class="lp-btn lp-btn--outline">
          {{ section.settings.hero_btn2_text }}
        </a>
      {%- endif -%}
    </div>
  </div>

  <div class="lp-hero__scroll-hint">
    <span class="lp-hero__scroll-line"></span>
    <span class="lp-hero__scroll-label">Scroll</span>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════
     COLLECTIONS WITH PRODUCTS
═══════════════════════════════════════════════════ -->
<div class="lp-cp-wrap">

  {%- assign col_index = 0 -%}
  {%- for collection in collections -%}
    {%- unless collection.handle == 'all' or collection.products_count == 0 -%}

      {%- assign col_index = col_index | plus: 1 -%}

      <!-- ── Editorial break after every 2nd collection ── -->
      {%- if col_index > 1 and col_index == 3 -%}
        {%- if section.settings.editorial_image != blank -%}
          <div class="lp-editorial">
            <img
              src="{{ section.settings.editorial_image | image_url: width: 2000 }}"
              alt="{{ section.settings.editorial_heading | default: '' | escape }}"
              class="lp-editorial__img"
              width="2000"
              height="1125"
              loading="lazy"
            >
            <div class="lp-editorial__overlay"></div>
            {%- if section.settings.editorial_heading != blank or section.settings.editorial_btn_text != blank -%}
              <div class="lp-editorial__content">
                {%- if section.settings.editorial_eyebrow != blank -%}
                  <p class="lp-editorial__eyebrow">{{ section.settings.editorial_eyebrow }}</p>
                {%- endif -%}
                {%- if section.settings.editorial_heading != blank -%}
                  <h2 class="lp-editorial__heading">{{ section.settings.editorial_heading }}</h2>
                {%- endif -%}
                {%- if section.settings.editorial_btn_text != blank -%}
                  <a href="{{ section.settings.editorial_btn_link | default: '#' }}" class="lp-editorial__btn">
                    {{ section.settings.editorial_btn_text }}
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endif -%}

      <section class="lp-cp">
        <div class="lp-container">
          <div class="lp-cp__head">
            <h2 class="lp-cp__title">{{ collection.title }}</h2>
          </div>
          <div class="lp-cp__grid">
            {%- for product in collection.products limit: 4 -%}
              {%- render 'card-product-urbnmyth', product: product -%}
            {%- endfor -%}
          </div>
          <div class="lp-cp__foot">
            <a href="{{ collection.url }}" class="lp-cp__view-all">View All</a>
          </div>
        </div>
      </section>

    {%- endunless -%}
  {%- endfor -%}

</div>

<!-- ═══════════════════════════════════════════════════
     STYLES
═══════════════════════════════════════════════════ -->
<style>
/* ── Base ────────────────────────────────────────── */
.lp-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 24px;
}

.lp-section {
  padding: 80px 0;
}

.lp-section-head {
  text-align: center;
  margin-bottom: 48px;
}

.lp-section-head--split {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  text-align: left;
  gap: 16px;
}

.lp-section-title {
  font-family: 'Oswald', sans-serif;
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  margin: 0 0 8px;
  color: #111;
}

.lp-section-sub {
  font-size: 1rem;
  color: #777;
  margin: 0;
  max-width: 480px;
}

.lp-link-arrow {
  font-size: 0.85rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #111;
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 6px;
  white-space: nowrap;
  border-bottom: 1px solid #111;
  padding-bottom: 2px;
  transition: color 0.2s, border-color 0.2s;
}

.lp-link-arrow:hover { color: #555; border-color: #555; }

/* ── Buttons ─────────────────────────────────────── */
.lp-btn {
  display: inline-block;
  padding: 14px 32px;
  font-family: 'Oswald', sans-serif;
  font-size: 0.9rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  border: 2px solid transparent;
  cursor: pointer;
  transition: background 0.25s, color 0.25s, border-color 0.25s;
}

.lp-btn--primary {
  background: #fff;
  color: #111;
  border-color: #fff;
}

.lp-btn--primary:hover { background: transparent; color: #fff; }

.lp-btn--outline {
  background: transparent;
  color: #fff;
  border-color: rgba(255,255,255,0.6);
}

.lp-btn--outline:hover { background: #fff; color: #111; border-color: #fff; }

.lp-btn--dark {
  background: #111;
  color: #fff;
  border-color: #111;
}

.lp-btn--dark:hover { background: transparent; color: #111; }

.lp-btn--outline-dark {
  background: transparent;
  color: #111;
  border: 2px solid #111;
}

.lp-btn--outline-dark:hover { background: #111; color: #fff; }

/* ── Hero ────────────────────────────────────────── */
.lp-hero {
  position: relative;
  width: 100%;
  height: 100svh;
  min-height: 560px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lp-hero__img-wrap,
.lp-hero__video-wrap {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.lp-hero__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

.lp-hero__img--kenburns {
  animation: lpKenBurns 16s ease-in-out infinite alternate;
  transform-origin: center center;
}

@keyframes lpKenBurns {
  from { transform: scale(1); }
  to   { transform: scale(1.08); }
}

.lp-hero__iframe {
  position: absolute;
  top: 50%;
  left: 50%;
  width: max(100%, 177.78vh);
  height: max(100%, 56.25vw);
  transform: translate(-50%, -50%);
  border: none;
  pointer-events: none;
}

.lp-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(0,0,0,0.15) 0%,
    rgba(0,0,0,0.5) 60%,
    rgba(0,0,0,0.75) 100%
  );
}

.lp-hero__content {
  position: relative;
  z-index: 2;
  text-align: center;
  color: #fff;
  padding: 0 24px;
  max-width: 820px;
}

.lp-hero__eyebrow {
  font-size: 0.78rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.7);
  margin: 0 0 16px;
}

.lp-hero__heading {
  font-family: 'Oswald', sans-serif;
  font-size: clamp(2.8rem, 8vw, 7rem);
  font-weight: 700;
  line-height: 0.95;
  letter-spacing: -0.01em;
  text-transform: uppercase;
  margin: 0 0 20px;
}

.lp-hero__subheading {
  font-size: clamp(0.95rem, 2vw, 1.2rem);
  color: rgba(255,255,255,0.8);
  margin: 0 0 40px;
  max-width: 480px;
  margin-left: auto;
  margin-right: auto;
}

.lp-hero__btns {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
}

.lp-hero__scroll-hint {
  position: absolute;
  bottom: 32px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  color: rgba(255,255,255,0.5);
  font-size: 0.65rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
}

.lp-hero__scroll-line {
  display: block;
  width: 1px;
  height: 48px;
  background: rgba(255,255,255,0.4);
  animation: lpScrollPulse 1.8s ease-in-out infinite;
}

@keyframes lpScrollPulse {
  0%, 100% { opacity: 0.4; transform: scaleY(1); }
  50%       { opacity: 1;   transform: scaleY(0.6); }
}

/* ── Marquee ─────────────────────────────────────── */
.lp-marquee {
  background: #111;
  color: #fff;
  overflow: hidden;
  padding: 14px 0;
  white-space: nowrap;
}

.lp-marquee__track {
  display: inline-flex;
  gap: 32px;
  animation: lpMarqueeScroll 32s linear infinite;
}

.lp-marquee__item {
  font-family: 'Oswald', sans-serif;
  font-size: 0.78rem;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  flex-shrink: 0;
}

.lp-marquee__sep {
  flex-shrink: 0;
  opacity: 0.4;
}

@keyframes lpMarqueeScroll {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

/* ── Collections ─────────────────────────────────── */
.lp-collections {
  background: #fafafa;
}

.lp-collections__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}

.lp-col-card {
  position: relative;
  display: block;
  text-decoration: none;
  overflow: hidden;
  aspect-ratio: 3/4;
}

.lp-col-card__img-wrap {
  position: absolute;
  inset: 0;
}

.lp-col-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.lp-col-card:hover .lp-col-card__img { transform: scale(1.06); }

.lp-col-card__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0) 55%);
}

.lp-col-card__info {
  position: absolute;
  bottom: 24px;
  left: 24px;
  right: 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #fff;
}

.lp-col-card__title {
  font-family: 'Oswald', sans-serif;
  font-size: 1.2rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.lp-col-card__arrow {
  font-size: 1.4rem;
  transition: transform 0.25s;
}

.lp-col-card:hover .lp-col-card__arrow { transform: translateX(6px); }

/* ── New Arrivals ────────────────────────────────── */
.lp-arrivals {
  background: #fff;
}

.lp-arrivals__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}

/* ── Brand Story ─────────────────────────────────── */
.lp-story {
  background: #f5f5f5;
  padding: 0;
  overflow: hidden;
}

.lp-story__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 600px;
}

.lp-story__inner--reversed { direction: rtl; }
.lp-story__inner--reversed > * { direction: ltr; }

.lp-story__img-side {
  position: relative;
  overflow: hidden;
}

.lp-story__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.8s ease;
}

.lp-story__img-side:hover .lp-story__img { transform: scale(1.04); }

.lp-story__caption {
  position: absolute;
  bottom: 20px;
  left: 20px;
  background: rgba(0,0,0,0.6);
  color: #fff;
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  padding: 6px 12px;
  text-transform: uppercase;
}

.lp-story__text-side {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 64px 72px;
  background: #fff;
}

.lp-story__eyebrow {
  display: inline-block;
  font-size: 0.72rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #888;
  margin-bottom: 20px;
}

.lp-story__heading {
  font-family: 'Oswald', sans-serif;
  font-size: clamp(2rem, 4vw, 3.2rem);
  font-weight: 700;
  line-height: 1;
  text-transform: uppercase;
  letter-spacing: 0.02em;
  margin: 0 0 24px;
  color: #111;
}

.lp-story__body {
  font-size: 1rem;
  line-height: 1.75;
  color: #555;
  margin-bottom: 36px;
}

/* ── Stats ───────────────────────────────────────── */
.lp-stats {
  background: #111;
  color: #fff;
  padding: 60px 0;
}

.lp-stats__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32px;
  text-align: center;
}

.lp-stats__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}

.lp-stats__num {
  font-family: 'Oswald', sans-serif;
  font-size: clamp(2rem, 4vw, 3.5rem);
  font-weight: 700;
  letter-spacing: 0.02em;
  line-height: 1;
}

.lp-stats__label {
  font-size: 0.78rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.5);
}

/* ── Testimonials ────────────────────────────────── */
.lp-testimonials {
  background: #fafafa;
}

.lp-testimonials__track {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.lp-testimonial-card {
  background: #fff;
  padding: 32px;
  border: 1px solid #ebebeb;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.lp-testimonial-card__stars {
  display: flex;
  gap: 3px;
}

.lp-star { color: #ddd; font-size: 1rem; }
.lp-star--filled { color: #f5a623; }

.lp-testimonial-card__quote {
  font-size: 0.95rem;
  line-height: 1.7;
  color: #333;
  margin: 0;
  flex: 1;
}

.lp-testimonial-card__author {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: 8px;
}

.lp-testimonial-card__avatar {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  object-fit: cover;
  flex-shrink: 0;
}

.lp-testimonial-card__avatar--initials {
  background: #111;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Oswald', sans-serif;
  font-size: 1rem;
  font-weight: 600;
}

.lp-testimonial-card__name {
  display: block;
  font-size: 0.88rem;
  font-weight: 700;
  color: #111;
}

.lp-testimonial-card__location {
  display: block;
  font-size: 0.75rem;
  color: #999;
  margin-top: 2px;
}

.lp-testimonials__dots {
  display: flex;
  justify-content: center;
  gap: 8px;
  margin-top: 32px;
}

/* ── Instagram ───────────────────────────────────── */
.lp-instagram { background: #fff; }

.lp-section-head { position: relative; }

.lp-insta-handle {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  font-size: 0.85rem;
  font-weight: 600;
  color: #111;
  text-decoration: none;
  letter-spacing: 0.04em;
  border-bottom: 1px solid #111;
  padding-bottom: 2px;
}

.lp-instagram__grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 4px;
}

.lp-insta-tile {
  position: relative;
  display: block;
  overflow: hidden;
  aspect-ratio: 1;
}

.lp-insta-tile__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.5s ease;
}

.lp-insta-tile:hover .lp-insta-tile__img { transform: scale(1.08); }

.lp-insta-tile__hover {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.lp-insta-tile:hover .lp-insta-tile__hover { opacity: 1; }

.lp-instagram__cta {
  text-align: center;
  margin-top: 36px;
}

/* ── Newsletter ──────────────────────────────────── */
.lp-newsletter {
  position: relative;
  padding: 100px 0;
  overflow: hidden;
  text-align: center;
}

.lp-newsletter__bg {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  background-attachment: fixed;
}

.lp-newsletter__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.72);
}

.lp-newsletter__content {
  position: relative;
  z-index: 2;
  color: #fff;
  max-width: 620px;
}

.lp-newsletter__eyebrow {
  display: block;
  font-size: 0.72rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.55);
  margin-bottom: 16px;
}

.lp-newsletter__heading {
  font-family: 'Oswald', sans-serif;
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  margin: 0 0 16px;
  line-height: 1;
}

.lp-newsletter__sub {
  font-size: 1rem;
  color: rgba(255,255,255,0.7);
  margin: 0 0 36px;
}

.lp-newsletter__input-wrap {
  display: flex;
  gap: 0;
  max-width: 520px;
  margin: 0 auto;
}

.lp-newsletter__input {
  flex: 1;
  padding: 16px 20px;
  border: 2px solid rgba(255,255,255,0.3);
  background: rgba(255,255,255,0.08);
  color: #fff;
  font-size: 0.95rem;
  outline: none;
  transition: border-color 0.25s;
}

.lp-newsletter__input::placeholder { color: rgba(255,255,255,0.4); }
.lp-newsletter__input:focus { border-color: rgba(255,255,255,0.7); }

.lp-newsletter__submit {
  padding: 16px 28px;
  background: #fff;
  color: #111;
  border: 2px solid #fff;
  font-family: 'Oswald', sans-serif;
  font-size: 0.85rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  cursor: pointer;
  transition: background 0.25s, color 0.25s;
  white-space: nowrap;
}

.lp-newsletter__submit:hover { background: transparent; color: #fff; }

.lp-newsletter__disclaimer {
  font-size: 0.72rem;
  color: rgba(255,255,255,0.4);
  margin-top: 14px;
}

/* ── Collections with Products ──────────────────── */
.lp-cp-wrap {
  background: #fff;
}

.lp-cp {
  padding: 36px 0;
  border-top: 1px solid #f0f0f0;
}

.lp-cp:first-child {
  border-top: none;
  padding-top: 32px;
}

.lp-cp__head {
  text-align: left;
  margin-bottom: 20px;
}

.lp-cp__tag {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #fff;
  background: #1a4fa3;
  padding: 3px 10px;
  border-radius: 2px;
  margin-bottom: 12px;
}

.lp-cp__title {
  font-size: clamp(1.5rem, 3vw, 2.2rem);
  font-weight: 800;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: #111;
  margin: 0;
}

.lp-cp__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}

.lp-cp__foot {
  text-align: center;
  margin-top: 36px;
}

.lp-cp__view-all {
  display: inline-block;
  padding: 12px 36px;
  border: 1.5px solid #111;
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #111;
  text-decoration: none;
  transition: background 0.2s, color 0.2s;
}

