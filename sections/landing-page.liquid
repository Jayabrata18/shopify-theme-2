<!--
  ═══════════════════════════════════════════════════
       JAVASCRIPT
  ═══════════════════════════════════════════════════
-->
<script>
  /* ── Scroll Reveal ── */
  (function () {
    var els = document.querySelectorAll('.lp-reveal');
    if (!els.length) return;

    if (!('IntersectionObserver' in window)) {
      els.forEach(function (el) { el.classList.add('lp-revealed'); });
      return;
    }

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('lp-revealed');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

    els.forEach(function (el) { observer.observe(el); });
  })();

  /* ── Product Card Interactions ── */
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.lp-collection .urbnmyth-product-image').forEach(function (wrap) {
      var imgs = (wrap.dataset.images || '').split('||').filter(Boolean);
      if (imgs.length < 2) return;
      var primary = wrap.querySelector('.urbnmyth-img-primary');
      var secondary = wrap.querySelector('.urbnmyth-img-secondary');
      if (!primary || !secondary) return;
      imgs.forEach(function (src) { new Image().src = src; });
      wrap.addEventListener('mouseenter', function () { primary.style.opacity = '0'; secondary.style.opacity = '1'; });
      wrap.addEventListener('mouseleave', function () { primary.style.opacity = '1'; secondary.style.opacity = '0'; });
    });

    try {
      var wl = JSON.parse(localStorage.getItem('urbnmyth_wishlist') || '[]');
      wl.forEach(function (id) {
        document.querySelectorAll('.lp-collection .urbnmyth-wishlist-btn[data-product-id="' + id + '"]')
          .forEach(function (btn) { btn.classList.add('urbnmyth-wishlisted'); });
      });
    } catch (e) {}
  });

  function urbnmythSelectSize(event, btn) {
    event.preventDefault();
    event.stopPropagation();
    var container = btn.closest('.urbnmyth-sizes');
    if (container) container.querySelectorAll('.urbnmyth-size-chip').forEach(function (c) { c.classList.remove('urbnmyth-size-selected'); });
    btn.classList.add('urbnmyth-size-selected');
    var card = btn.closest('.urbnmyth-product-card');
    if (card && btn.dataset.variantId) {
      var addBtn = card.querySelector('.urbnmyth-hover-add-btn');
      if (addBtn) addBtn.setAttribute('onclick', "urbnmythQuickAddToCart(event,'" + btn.dataset.variantId + "',this)");
    }
  }

  function urbnmythQuickAddToCart(event, variantId, button) {
    event.preventDefault();
    event.stopPropagation();
    var orig = button.innerHTML;
    button.innerHTML = 'Adding...';
    button.disabled = true;
    var fd = new FormData();
    fd.append('id', variantId);
    fd.append('quantity', 1);
    fetch('/cart/add.js', { method: 'POST', body: fd })
      .then(function (r) { return r.json(); })
      .then(function () { button.innerHTML = 'Added!'; setTimeout(function () { window.location.href = '/cart'; }, 600); })
      .catch(function () {
        button.innerHTML = 'Error — Try Again';
        button.style.background = '#dc3545';
        button.style.color = '#fff';
        setTimeout(function () { button.innerHTML = orig; button.disabled = false; button.style.background = ''; button.style.color = ''; }, 2000);
      });
  }

  function urbnmythManualCycle(event, btn) {
    event.preventDefault();
    event.stopPropagation();
    var wrap = btn.closest('.urbnmyth-product-image');
    if (!wrap) return;
    var imgs = (wrap.dataset.images || '').split('||').filter(Boolean);
    if (imgs.length < 2) return;
    var primary = wrap.querySelector('.urbnmyth-img-primary');
    var secondary = wrap.querySelector('.urbnmyth-img-secondary');
    if (!primary || !secondary) return;
    var idx = (parseInt(wrap.dataset.manualIndex || '1', 10) + 1) % imgs.length;
    wrap.dataset.manualIndex = idx;
    secondary.src = imgs[idx];
    primary.style.opacity = '0';
    secondary.style.opacity = '1';
  }

  function urbnmythQuickView(event, url) {
    event.preventDefault();
    event.stopPropagation();
    window.open(url + '?quickview=1', '_blank', 'noopener');
  }

  function urbnmythToggleWishlist(event, productId, btn) {
    event.preventDefault();
    event.stopPropagation();
    try {
      var wl = JSON.parse(localStorage.getItem('urbnmyth_wishlist') || '[]');
      var idx = wl.indexOf(String(productId));
      if (idx === -1) { wl.push(String(productId)); btn.classList.add('urbnmyth-wishlisted'); }
      else            { wl.splice(idx, 1);           btn.classList.remove('urbnmyth-wishlisted'); }
      localStorage.setItem('urbnmyth_wishlist', JSON.stringify(wl));
    } catch (e) {}
  }
</script>

