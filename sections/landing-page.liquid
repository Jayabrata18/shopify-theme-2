  /* ── Mobile ──────────────────────────────────────── */
  @media (max-width: 900px) {
    .lp-cp__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .lp-cp {
      padding: 24px 0;
    }
    .lp-cp:first-child {
      padding-top: 20px;
    }
    .lp-cp__title {
      font-size: 1.2rem;
    }
    .lp-editorial {
      height: clamp(220px, 60vw, 360px);
    }
  }

  @media (max-width: 580px) {
    .lp-cp {
      padding: 18px 0;
    }
    .lp-cp__grid {
      gap: 10px;
    }
  }
</style>

<script>
  /* ── Card JS for landing page ── */
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.lp-cp-wrap .urbnmyth-product-image').forEach(function (imageWrap) {
      const rawImages = (imageWrap.dataset.images || '').split('||').filter(Boolean);
      if (rawImages.length < 2) return;
      const primary = imageWrap.querySelector('.urbnmyth-img-primary');
      const secondary = imageWrap.querySelector('.urbnmyth-img-secondary');
      if (!primary || !secondary) return;
      rawImages.forEach(function (src) {
        const img = new Image();
        img.src = src;
      });
      imageWrap.addEventListener('mouseenter', function () {
        primary.style.opacity = '0';
        secondary.style.opacity = '1';
      });
      imageWrap.addEventListener('mouseleave', function () {
        primary.style.opacity = '1';
        secondary.style.opacity = '0';
      });
    });

    try {
      const wl = JSON.parse(localStorage.getItem('urbnmyth_wishlist') || '[]');
      wl.forEach(function (id) {
        document
          .querySelectorAll('.lp-cp-wrap .urbnmyth-wishlist-btn[data-product-id="' + id + '"]')
          .forEach(function (btn) {
            btn.classList.add('urbnmyth-wishlisted');
          });
      });
    } catch (e) {}
  });

  function urbnmythSelectSize(event, btn) {
    event.preventDefault();
    event.stopPropagation();
    const sizeContainer = btn.closest('.urbnmyth-sizes');
    if (sizeContainer)
      sizeContainer.querySelectorAll('.urbnmyth-size-chip').forEach(function (chip) {
        chip.classList.remove('urbnmyth-size-selected');
      });
    btn.classList.add('urbnmyth-size-selected');
    const card = btn.closest('.urbnmyth-product-card');
    if (card && btn.dataset.variantId) {
      const quickAddBtn = card.querySelector('.urbnmyth-hover-add-btn');
      if (quickAddBtn)
        quickAddBtn.setAttribute('onclick', "urbnmythQuickAddToCart(event, '" + btn.dataset.variantId + "', this)");
    }
  }

  function urbnmythQuickAddToCart(event, variantId, button) {
    event.preventDefault();
    event.stopPropagation();
    const originalHTML = button.innerHTML;
    button.innerHTML = 'Adding...';
    button.disabled = true;
    const formData = new FormData();
    formData.append('id', variantId);
    formData.append('quantity', 1);
    fetch('/cart/add.js', { method: 'POST', body: formData })
      .then((r) => r.json())
      .then(() => {
        button.innerHTML = 'Added!';
        setTimeout(() => {
          window.location.href = '/cart';
        }, 600);
      })
      .catch(() => {
        button.innerHTML = 'Error — Try Again';
        button.style.background = '#dc3545';
        button.style.color = '#fff';
        setTimeout(() => {
          button.innerHTML = originalHTML;
          button.disabled = false;
          button.style.background = '';
          button.style.color = '';
        }, 2000);
      });
  }

  function urbnmythManualCycle(event, btn) {
    event.preventDefault();
    event.stopPropagation();
    const imageWrap = btn.closest('.urbnmyth-product-image');
    if (!imageWrap) return;
    const rawImages = (imageWrap.dataset.images || '').split('||').filter(Boolean);
    if (rawImages.length < 2) return;
    const primary = imageWrap.querySelector('.urbnmyth-img-primary');
    const secondary = imageWrap.querySelector('.urbnmyth-img-secondary');
    if (!primary || !secondary) return;
    let idx = parseInt(imageWrap.dataset.manualIndex || '1', 10);
    idx = (idx + 1) % rawImages.length;
    imageWrap.dataset.manualIndex = idx;
    secondary.src = rawImages[idx];
    primary.style.opacity = '0';
    secondary.style.opacity = '1';
  }

  function urbnmythQuickView(event, productUrl) {
    event.preventDefault();
    event.stopPropagation();
    window.open(productUrl + '?quickview=1', '_blank', 'noopener');
  }

  function urbnmythToggleWishlist(event, productId, btn) {
    event.preventDefault();
    event.stopPropagation();
    try {
      let wl = JSON.parse(localStorage.getItem('urbnmyth_wishlist') || '[]');
      const idx = wl.indexOf(String(productId));
      if (idx === -1) {
        wl.push(String(productId));
        btn.classList.add('urbnmyth-wishlisted');
      } else {
        wl.splice(idx, 1);
        btn.classList.remove('urbnmyth-wishlisted');
      }
      localStorage.setItem('urbnmyth_wishlist', JSON.stringify(wl));
    } catch (e) {}
  }
</script>

