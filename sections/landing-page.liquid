  @media (max-width: 580px) {
    .lp-container { padding: 0 16px; }
    .lp-collection { padding: 28px 0; }
    .lp-collection__grid { gap: 10px; }
    .lp-community__layout { padding: 44px 20px; gap: 36px; }
