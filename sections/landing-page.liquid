<!--
  ═══════════════════════════════════════════════════
       HERO SECTION
  ═══════════════════════════════════════════════════
-->
<section class="lp-hero" id="lp-hero">
  {%- assign hero_bg = section.settings.hero_image | image_url: width: 2000 -%}
  {%- if section.settings.hero_youtube_id != blank -%}
    <div class="lp-hero__video-wrap">
      <iframe
        class="lp-hero__iframe"
        src="https://www.youtube.com/embed/{{ section.settings.hero_youtube_id }}?autoplay=1&mute=1&loop=1&playlist={{ section.settings.hero_youtube_id }}&controls=0&showinfo=0&rel=0&modestbranding=1"
        frameborder="0"
        allow="autoplay; fullscreen"
        allowfullscreen
      ></iframe>
      <div class="lp-hero__overlay"></div>
    </div>
  {%- elsif section.settings.hero_image != blank -%}
    <div class="lp-hero__img-wrap">
      <img
        src="{{ hero_bg }}"
        alt="{{ section.settings.hero_heading | escape }}"
        width="2000"
        height="1200"
        class="lp-hero__img lp-hero__img--kenburns"
        loading="eager"
      >
      <div class="lp-hero__overlay"></div>
    </div>
  {%- else -%}
    <div class="lp-hero__img-wrap">
      <img
        src="https://images.unsplash.com/photo-1523398002811-999ca8dec234?w=2000&q=80&fit=crop"
        alt="Hero"
        width="2000"
        height="1200"
        class="lp-hero__img lp-hero__img--kenburns"
        loading="eager"
      >
      <div class="lp-hero__overlay"></div>
    </div>
  {%- endif -%}

  <div class="lp-hero__content">
    {%- if section.settings.hero_eyebrow != blank -%}
      <p class="lp-hero__eyebrow">{{ section.settings.hero_eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.hero_heading != blank -%}
      <h1 class="lp-hero__heading">{{ section.settings.hero_heading }}</h1>
    {%- endif -%}
    {%- if section.settings.hero_subheading != blank -%}
      <p class="lp-hero__subheading">{{ section.settings.hero_subheading }}</p>
    {%- endif -%}
    <div class="lp-hero__btns">
      {%- if section.settings.hero_btn1_text != blank -%}
        <a href="{{ section.settings.hero_btn1_link }}" class="lp-btn lp-btn--primary">
          {{ section.settings.hero_btn1_text }}
        </a>
      {%- endif -%}
      {%- if section.settings.hero_btn2_text != blank -%}
        <a href="{{ section.settings.hero_btn2_link }}" class="lp-btn lp-btn--outline">
          {{ section.settings.hero_btn2_text }}
        </a>
      {%- endif -%}
    </div>
  </div>

  <div class="lp-hero__scroll-hint">
    <span class="lp-hero__scroll-line"></span>
    <span class="lp-hero__scroll-label">Scroll</span>
  </div>
</section>

<!--
  ═══════════════════════════════════════════════════
       COLLECTIONS WITH PRODUCTS
  ═══════════════════════════════════════════════════
-->
<div class="lp-cp-wrap">
  {%- assign col_index = 0 -%}
  {%- for collection in collections -%}
    {%- unless collection.handle == 'all' or collection.products_count == 0 -%}
      {%- assign col_index = col_index | plus: 1 -%}

      <!-- ── Editorial break after every 2nd collection ── -->
      {%- if col_index == 3 -%}
        {%- if section.settings.editorial_image != blank -%}
          <div class="lp-editorial">
            <img
              src="{{ section.settings.editorial_image | image_url: width: 2000 }}"
              alt="{{ section.settings.editorial_heading | default: '' | escape }}"
              class="lp-editorial__img"
              width="2000"
              height="1125"
              loading="lazy"
            >
            <div class="lp-editorial__overlay"></div>
            {%- if section.settings.editorial_heading != blank or section.settings.editorial_btn_text != blank -%}
              <div class="lp-editorial__content">
                {%- if section.settings.editorial_eyebrow != blank -%}
                  <p class="lp-editorial__eyebrow">{{ section.settings.editorial_eyebrow }}</p>
                {%- endif -%}
                {%- if section.settings.editorial_heading != blank -%}
                  <h2 class="lp-editorial__heading">{{ section.settings.editorial_heading }}</h2>
                {%- endif -%}
                {%- if section.settings.editorial_btn_text != blank -%}
                  <a href="{{ section.settings.editorial_btn_link | default: '#' }}" class="lp-editorial__btn">
                    {{ section.settings.editorial_btn_text }}
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endif -%}

      <section class="lp-cp">
        <div class="lp-container">
          <div class="lp-cp__head">
            <h2 class="lp-cp__title">{{ collection.title }}</h2>
          </div>
          <div class="lp-cp__grid">
            {%- for product in collection.products limit: 4 -%}
              {%- render 'card-product-urbnmyth', product: product -%}
            {%- endfor -%}
          </div>
          <div class="lp-cp__foot">
            <a href="{{ collection.url }}" class="lp-cp__view-all">View All</a>
          </div>
        </div>
      </section>
    {%- endunless -%}
  {%- endfor -%}
</div>

<!--
  ═══════════════════════════════════════════════════
       STYLES
  ═══════════════════════════════════════════════════
-->
<style>
  /* ── Base ────────────────────────────────────────── */
  .lp-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Buttons ─────────────────────────────────────── */
  .lp-btn {
    display: inline-block;
    padding: 14px 32px;
    font-family: 'Oswald', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border: 2px solid transparent;
    cursor: pointer;
    transition: background 0.25s, color 0.25s, border-color 0.25s;
  }

  .lp-btn--primary {
    background: #fff;
    color: #111;
    border-color: #fff;
  }

  .lp-btn--primary:hover {
    background: transparent;
    color: #fff;
  }

  .lp-btn--outline {
    background: transparent;
    color: #fff;
    border-color: rgba(255, 255, 255, 0.6);
  }

  .lp-btn--outline:hover {
    background: #fff;
    color: #111;
    border-color: #fff;
  }

  /* ── Hero ────────────────────────────────────────── */
  .lp-hero {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 560px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lp-hero__img-wrap,
  .lp-hero__video-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .lp-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .lp-hero__img--kenburns {
    animation: lpKenBurns 16s ease-in-out infinite alternate;
    transform-origin: center center;
  }

  @keyframes lpKenBurns {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.08);
    }
  }

  .lp-hero__iframe {
    position: absolute;
    top: 50%;
    left: 50%;
    width: max(100%, 177.78vh);
    height: max(100%, 56.25vw);
    transform: translate(-50%, -50%);
    border: none;
    pointer-events: none;
  }

  .lp-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.15) 0%, rgba(0, 0, 0, 0.5) 60%, rgba(0, 0, 0, 0.75) 100%);
  }

  .lp-hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: #fff;
    padding: 0 24px;
    max-width: 820px;
  }

  .lp-hero__eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    margin: 0 0 16px;
  }

  .lp-hero__heading {
    font-family: 'Oswald', sans-serif;
    font-size: clamp(2.8rem, 8vw, 7rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    margin: 0 0 20px;
  }

  .lp-hero__subheading {
    font-size: clamp(0.95rem, 2vw, 1.2rem);
    color: rgba(255, 255, 255, 0.8);
    margin: 0 0 40px;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  .lp-hero__btns {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .lp-hero__scroll-hint {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .lp-hero__scroll-line {
    display: block;
    width: 1px;
    height: 48px;
    background: rgba(255, 255, 255, 0.4);
    animation: lpScrollPulse 1.8s ease-in-out infinite;
  }

  @keyframes lpScrollPulse {
    0%,
    100% {
      opacity: 0.4;
      transform: scaleY(1);
    }
    50% {
      opacity: 1;
      transform: scaleY(0.6);
    }
  }

  /* ── Collections with Products ──────────────────── */
  .lp-cp-wrap {
    background: #fff;
  }

  .lp-cp {
    padding: 36px 0;
    border-top: 1px solid #f0f0f0;
  }

  .lp-cp:first-child {
    border-top: none;
    padding-top: 32px;
  }

  .lp-cp__head {
    text-align: left;
    margin-bottom: 20px;
  }

  .lp-cp__title {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #111;
    margin: 0;
  }

  .lp-cp__grid {
