<style>
  *, *::before, *::after { box-sizing: border-box; }

  :root {
    --urbn-black: #111111;
    --urbn-white: #ffffff;
    --urbn-gray-100: #f5f4f2;
    --urbn-gray-200: #e8e6e2;
    --urbn-gray-400: #9a9792;
    --urbn-nav-h: 64px;
    --urbn-menu-w: 320px;
  }

  .urbn-announcement {
    background: var(--urbn-black);
    color: var(--urbn-white);
    text-align: center;
    font-size: 11px;
    letter-spacing: 0.18em;
    padding: 8px 16px;
    text-transform: uppercase;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  .urbn-nav {
    background: var(--urbn-white);
    height: var(--urbn-nav-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px;
    border-bottom: 1px solid var(--urbn-gray-200);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .urbn-nav-left,
  .urbn-nav-right {
    display: flex;
    align-items: center;
    gap: 4px;
    flex: 1;
  }
  .urbn-nav-right { justify-content: flex-end; }

  .urbn-nav-center {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }
  .urbn-nav-center a {
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .urbn-nav-center img {
    height: 38px;
    width: auto;
    display: block;
  }
  .urbn-brand-fallback {
    font-family: 'Georgia', 'Times New Roman', serif;
    font-size: 22px;
    letter-spacing: 0.3em;
    color: var(--urbn-black);
    text-transform: uppercase;
    font-weight: 400;
  }

  .urbn-icon-btn {
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    transition: background 0.15s;
    color: var(--urbn-black);
    position: relative;
    padding: 0;
    text-decoration: none;
  }
  .urbn-icon-btn:hover { background: var(--urbn-gray-100); }
  .urbn-icon-btn svg {
    width: 22px;
    height: 22px;
    stroke: var(--urbn-black);
    fill: none;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
    flex-shrink: 0;
  }

  /* ── HAMBURGER ANIMATION ── */
  .urbn-burger {
    width: 22px;
    height: 22px;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
  }
  .urbn-burger span {
    display: block;
    height: 1.6px;
    background: var(--urbn-black);
    border-radius: 2px;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.25s ease,
                width 0.3s ease;
    transform-origin: center;
  }
  .urbn-burger span:nth-child(1) { width: 22px; }
  .urbn-burger span:nth-child(2) { width: 16px; }
  .urbn-burger span:nth-child(3) { width: 22px; }

  .urbn-burger.is-open span:nth-child(1) {
    transform: translateY(6.6px) rotate(45deg);
    width: 22px;
  }
  .urbn-burger.is-open span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .urbn-burger.is-open span:nth-child(3) {
    transform: translateY(-6.6px) rotate(-45deg);
    width: 22px;
  }

  .urbn-cart-wrap { position: relative; display: flex; align-items: center; }
  .urbn-cart-badge {
    position: absolute;
    top: 5px; right: 5px;
    background: var(--urbn-black);
    color: var(--urbn-white);
    font-size: 8px;
    font-family: 'Helvetica Neue', sans-serif;
    font-weight: 700;
    width: 14px; height: 14px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }
  .urbn-cart-badge[data-count="0"] { display: none; }

  .urbn-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0);
    z-index: 200;
    pointer-events: none;
    transition: background 0.35s ease;
  }
  .urbn-overlay.is-open {
    background: rgba(0,0,0,0.45);
    pointer-events: all;
  }

  .urbn-slide-menu {
    position: fixed;
    top: 0; left: 0;
    width: var(--urbn-menu-w);
    max-width: 85vw;
    height: 100%;
    background: var(--urbn-white);
    z-index: 300;
    transform: translateX(-100%);
    transition: transform 0.38s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .urbn-slide-menu.is-open { transform: translateX(0); }

  .urbn-menu-header {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 0 16px;
    height: var(--urbn-nav-h);
    border-bottom: 1px solid var(--urbn-gray-200);
    flex-shrink: 0;
  }

  .urbn-menu-body {
    flex: 1;
    overflow-y: auto;
    padding: 8px 0 24px;
    -webkit-overflow-scrolling: touch;
  }

  .urbn-menu-section-label {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--urbn-gray-400);
    text-transform: uppercase;
    padding: 20px 24px 8px;
  }

  .urbn-menu-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 13px 24px;
    text-decoration: none;
    color: var(--urbn-black);
    transition: background 0.15s;
    -webkit-tap-highlight-color: transparent;
  }
  .urbn-menu-item:hover,
  .urbn-menu-item:focus { background: var(--urbn-gray-100); outline: none; }
  .urbn-menu-item:active { background: var(--urbn-gray-200); }

  .urbn-menu-icon {
    width: 38px; height: 38px;
    background: var(--urbn-gray-100);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.15s;
  }
  .urbn-menu-item:hover .urbn-menu-icon { background: var(--urbn-gray-200); }
  .urbn-menu-icon svg {
    width: 18px; height: 18px;
    stroke: var(--urbn-black);
    fill: none;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .urbn-menu-text { flex: 1; }
  .urbn-menu-text span {
    display: block;
    font-size: 15px;
    font-family: 'Georgia', 'Times New Roman', serif;
    color: var(--urbn-black);
    letter-spacing: 0.02em;
  }
  .urbn-menu-text small {
    display: block;
    font-size: 11px;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    color: var(--urbn-gray-400);
    margin-top: 2px;
    letter-spacing: 0.02em;
  }

  .urbn-menu-arrow svg {
    width: 16px; height: 16px;
    stroke: var(--urbn-gray-400);
    fill: none;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .urbn-menu-divider {
    height: 1px;
    background: var(--urbn-gray-200);
    margin: 8px 24px;
  }

  .urbn-menu-footer {
    padding: 16px 24px;
    border-top: 1px solid var(--urbn-gray-200);
    flex-shrink: 0;
  }
  .urbn-menu-footer-links {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }
  .urbn-menu-footer-links a {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--urbn-gray-400);
    text-decoration: none;
    text-transform: uppercase;
  }
  .urbn-menu-footer-links a:hover { color: var(--urbn-black); }

  @media (max-width: 480px) {
    :root { --urbn-nav-h: 58px; }
    .urbn-announcement { font-size: 10px; letter-spacing: 0.1em; padding: 7px 12px; }
    .urbn-nav-center img { height: 32px; }
    .urbn-brand-fallback { font-size: 18px; }
    .urbn-icon-btn { width: 36px; height: 36px; }
    .urbn-icon-btn svg { width: 20px; height: 20px; }
  }
</style>

{% if section.settings.announcement_text != blank %}
  <div class="urbn-announcement">{{ section.settings.announcement_text }}</div>
{% endif %}

<nav class="urbn-nav" role="navigation" aria-label="Main navigation">

  <div class="urbn-nav-left">
    <button class="urbn-icon-btn" id="urbn-burger-btn" aria-label="Open menu" aria-expanded="false" aria-controls="urbn-slide-menu">
      <div class="urbn-burger" id="urbn-burger-icon">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </button>
    <button class="urbn-icon-btn" aria-label="Search" id="urbn-search-btn">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <circle cx="11" cy="11" r="7"/>
        <line x1="16.5" y1="16.5" x2="22" y2="22"/>
      </svg>
    </button>
  </div>

  <div class="urbn-nav-center">
    <a href="{{ routes.root_url }}" aria-label="{{ shop.name }} home">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url }}" alt="{{ shop.name }}" width="160" height="38" loading="eager">
      {%- else -%}
        <img
          src="https://cdn.shopify.com/s/files/1/0782/0689/4322/files/URBNMYTH_word_mark_1.svg?v=1778783944"
          alt="{{ shop.name }}"
          width="160"
          height="38"
          loading="eager"
          onerror="this.style.display='none';this.nextElementSibling.style.display='block';"
        >
        <span class="urbn-brand-fallback" style="display:none;">{{ shop.name }}</span>
      {%- endif -%}
    </a>
  </div>

  <div class="urbn-nav-right">
    {%- if shop.customer_accounts_enabled -%}
      <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="urbn-icon-btn" aria-label="{%- if customer -%}My Account{%- else -%}Log in{%- endif -%}">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="12" cy="8" r="4"/>
          <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
        </svg>
      </a>
    {%- endif -%}
    <div class="urbn-cart-wrap">
      <a href="{{ routes.cart_url }}" class="urbn-icon-btn" aria-label="Cart ({{ cart.item_count }} items)">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
      </a>
      <span class="urbn-cart-badge" data-count="{{ cart.item_count }}" aria-hidden="true">{{ cart.item_count }}</span>
    </div>
  </div>

</nav>

