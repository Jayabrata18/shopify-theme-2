{%- style -%}
.cs-section {
  background: #fff;
  padding: clamp(3rem, 6vw, 5rem) clamp(1.5rem, 5vw, 4rem);
  border-top: 1px solid #ebebeb;
  border-bottom: 1px solid #ebebeb;
  overflow: hidden;
}

.cs-grid {
  max-width: 80rem;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2rem;
}

@media (max-width: 900px) {
  .cs-grid { grid-template-columns: repeat(2, 1fr); gap: 2.5rem 1.5rem; }
}
@media (max-width: 480px) {
  .cs-grid { grid-template-columns: 1fr 1fr; gap: 2rem 1rem; }
}

.cs-item {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1),
              transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
}
.cs-item.cs-visible {
  opacity: 1;
  transform: translateY(0);
}
.cs-item:nth-child(1) { transition-delay: 0.05s; }
.cs-item:nth-child(2) { transition-delay: 0.15s; }
.cs-item:nth-child(3) { transition-delay: 0.25s; }
.cs-item:nth-child(4) { transition-delay: 0.35s; }

.cs-icon {
  width: clamp(2rem, 4vw, 2.8rem);
  height: clamp(2rem, 4vw, 2.8rem);
  color: #111;
  flex-shrink: 0;
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.cs-item:hover .cs-icon {
  transform: scale(1.15) translateY(-3px);
}

.cs-title {
  font-size: clamp(0.85rem, 1.4vw, 1rem);
  font-weight: 700;
  color: #111;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  line-height: 1.2;
  margin: 0;
}

.cs-desc {
  font-size: clamp(0.75rem, 1.1vw, 0.85rem);
  color: #777;
  line-height: 1.5;
  margin: 0;
}

/* Dividers between items on desktop */
@media (min-width: 901px) {
  .cs-item + .cs-item {
    border-left: 1px solid #ebebeb;
    padding-left: 2rem;
  }
}
{%- endstyle -%}

<section class="cs-section" aria-label="Customer support features">
  <div class="cs-grid" id="csGrid">

    <!-- Online Support -->
    <div class="cs-item">
      <svg class="cs-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 18v-6a9 9 0 0 1 18 0v6"/>
        <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3v5z"/>
        <path d="M3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3v5z"/>
      </svg>
      <p class="cs-title">Online Support</p>
      <p class="cs-desc">24 hours a day, 7 days a week</p>
    </div>

    <!-- Free Shipping -->
    <div class="cs-item">
      <svg class="cs-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M1 3h15v13H1z"/>
        <path d="M16 8h4l3 3v5h-7V8z"/>
        <circle cx="5.5" cy="18.5" r="2.5"/>
        <circle cx="18.5" cy="18.5" r="2.5"/>
      </svg>
      <p class="cs-title">Free Shipping</p>
      <p class="cs-desc">Free shipping on all prepaid orders</p>
    </div>

    <!-- Easy Returns -->
    <div class="cs-item">
      <svg class="cs-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
        <path d="M3 3v5h5"/>
        <path d="M12 7v5l4 2"/>
      </svg>
      <p class="cs-title">Easy Returns</p>
      <p class="cs-desc">Hassle-free exchanges and returns within 7 days</p>
    </div>

    <!-- Secure Payments -->
    <div class="cs-item">
      <svg class="cs-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="5" width="20" height="14" rx="2"/>
        <line x1="2" y1="10" x2="22" y2="10"/>
        <line x1="6" y1="15" x2="10" y2="15"/>
        <circle cx="17" cy="15" r="1" fill="currentColor"/>
        <circle cx="20" cy="15" r="1" fill="currentColor"/>
      </svg>
      <p class="cs-title">Secure Payments</p>
      <p class="cs-desc">Pay via Credit Cards, UPI, Apple Pay &amp; more</p>
    </div>

  </div>
</section>

<script>
(function () {
  var items = document.querySelectorAll('#csGrid .cs-item');
  if (!items.length) return;

  if ('IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('cs-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });

    items.forEach(function (item) { observer.observe(item); });
  } else {
    items.forEach(function (item) { item.classList.add('cs-visible'); });
  }
})();
</script>
