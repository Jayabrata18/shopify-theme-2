{%- style -%}
  .ft {
    background: #0d0d0d;
    color: #fff;
    font-family: var(--font-body, sans-serif);
  }

  /* -- Top grid ------------------------------------- */
  .ft-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    max-width: 1280px;
    margin: 0 auto;
    padding: 3.5rem 1.25rem 2.5rem;
  }
  @media (min-width: 640px) {
    .ft-grid { grid-template-columns: repeat(2, 1fr); gap: 2rem 3rem; }
  }
  @media (min-width: 900px) {
    .ft-grid { grid-template-columns: 1.4fr 1fr 1fr 1fr 1.5fr; gap: 2rem; }
  }

  /* -- Column headings ----------------------------------------------------------------------------------- */
  .ft-col__heading {
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 800;
    color: #fff;
    margin: 0 0 1.25rem;
  }

  /* -- Contact column -------------------------------------------------------------------------------------- */
  .ft-logo {
    display: block;
    height: 1.6rem;
    width: auto;
    margin-bottom: 1.5rem;
    filter: brightness(0) invert(1);
  }

  .ft-contact-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .ft-contact-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .ft-contact-item__icon {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: rgba(255,255,255,0.55);
  }

  .ft-contact-item__icon svg {
    width: 0.9rem;
    height: 0.9rem;
  }

  .ft-contact-item__body strong {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 1px;
  }

  .ft-contact-item__body span {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.35);
  }

  .ft-contact-item a {
    text-decoration: none;
    color: inherit;
  }

  /* -- Social icons -------------------------------------------------------------------------------------------- */
  .ft-social-label {
    font-size: 0.65rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    font-weight: 700;
    color: rgba(255,255,255,0.38);
    margin-bottom: 0.75rem;
  }

  .ft-social-icons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .ft-social-icons a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    transition: background 0.25s, color 0.25s, transform 0.2s;
  }

  .ft-social-icons a:hover {
    background: #C41E1E;
    color: #fff;
    transform: translateY(-2px);
  }

  .ft-social-icons svg {
    width: 0.85rem;
    height: 0.85rem;
  }

  /* -- Link columns -------------------------------------------------------------------------------------------- */
  .ft-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .ft-links a {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .ft-links a:hover { color: #fff; }

  /* -- Newsletter column ----------------------------------------------------------------------------- */
  .ft-newsletter__heading {
    font-family: var(--font-heading, serif);
    font-size: 1.15rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .ft-newsletter__sub {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.38);
    line-height: 1.6;
    margin: 0 0 1.25rem;
  }

  .ft-newsletter__form {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .ft-newsletter__input {
    width: 100%;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.12);
    padding: 0.75rem 1rem;
    font-size: 0.8rem;
    color: #fff;
    outline: none;
    font-family: inherit;
    box-sizing: border-box;
    transition: border-color 0.25s;
  }

  .ft-newsletter__input::placeholder { color: rgba(255,255,255,0.25); }
  .ft-newsletter__input:focus { border-color: rgba(255,255,255,0.4); }

  .ft-newsletter__btn {
    width: 100%;
    background: #fff;
    color: #111;
    border: none;
    padding: 0.75rem 1rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.25s, color 0.25s;
  }

  .ft-newsletter__btn:hover { background: #e0e0e0; }

  /* -- Bottom bar -------------------------------------------------------------------------------------------------- */
  .ft-bottom {
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }

  @media (min-width: 640px) {
    .ft-bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .ft-bottom__copy {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.2);
    margin: 0;
  }

  .ft-bottom__links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .ft-bottom__links a {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.2);
    text-decoration: none;
    transition: color 0.2s;
  }

  .ft-bottom__links a:hover { color: rgba(255,255,255,0.5); }

  .ft-bottom__sep {
    color: rgba(255,255,255,0.1);
    font-size: 0.6rem;
  }

  .ft-bottom__dot {
    display: inline-block;
    width: 5px;
    height: 5px;
    background: #C41E1E;
    border-radius: 50%;
  }

  /* -- Mobile tweaks ----------------------------------------------------------------------------------------- */
  @media (max-width: 639px) {
    .ft-grid > *:nth-child(5) { grid-column: span 1; }
  }
  @media (min-width: 640px) and (max-width: 899px) {
    .ft-grid > *:nth-child(5) { grid-column: span 2; }
    .ft-newsletter__form { flex-direction: row; }
    .ft-newsletter__input { flex: 1; }
    .ft-newsletter__btn { width: auto; white-space: nowrap; }
  }
{%- endstyle -%}

