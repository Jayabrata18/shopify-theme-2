      <span class="ft-bottom__sep">&middot;</span>
      <a href="{{ routes.root_url }}policies/terms-of-service">Terms</a>
      <span class="ft-bottom__sep">&middot;</span>
      <a href="{{ routes.root_url }}policies/shipping-policy">Shipping</a>
    </div>
  </div>
</footer>

