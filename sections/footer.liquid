{%- comment -%}
  footer.liquid — Converted from React Footer component
  Include: {% render 'footer' %}
{%- endcomment -%}

{%- style -%}
  .footer {
    background-color: #0d0d0d;
    color: #fff;
    overflow: hidden;
  }
  .footer-container {
    max-width: 80rem;
    margin: 0 auto;
    padding: 4rem 1rem 2.5rem;
  }
  @media (min-width: 640px) {
    .footer-container { padding: 4rem 1.5rem 2.5rem; }
  }
  @media (min-width: 1024px) {
    .footer-container { padding: 4rem 2rem 2.5rem; }
  }

  /* Marquee */
  .footer-marquee {
    border-bottom: 1px solid rgba(255,255,255,0.05);
    overflow: hidden;
  }
  .marquee-track {
    display: flex;
    white-space: nowrap;
    padding: 1.5rem 0;
    animation: footer-marquee 30s linear infinite;
  }
  .marquee-track span {
    font-family: var(--font-heading, serif);
    font-size: 3rem;
    font-weight: bold;
    color: rgba(255,255,255,0.04);
    user-select: none;
    padding: 0 2rem;
  }
  @media (min-width: 640px) {
    .marquee-track span { font-size: 4.5rem; }
  }
  @keyframes footer-marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Grid */
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    margin-bottom: 4rem;
  }
  @media (min-width: 640px) {
    .footer-grid { grid-template-columns: repeat(2, 1fr); gap: 3rem; }
  }
  @media (min-width: 1024px) {
    .footer-grid { grid-template-columns: repeat(4, 1fr); gap: 3rem; }
  }
  .footer-grid .brand-col {
    grid-column: span 1;
  }
  @media (min-width: 640px) {
    .footer-grid .brand-col { grid-column: span 2; }
  }
  @media (min-width: 1024px) {
    .footer-grid .brand-col { grid-column: span 1; }
  }

  /* Brand */
  .footer-logo {
    height: 1.75rem;
    margin-bottom: 1.25rem;
    filter: brightness(0) invert(1);
    opacity: 0;
    animation: fadeIn 0.8s forwards;
  }
  @keyframes fadeIn {
    to { opacity: 1; }
  }
  .footer-desc {
    color: rgba(255,255,255,0.35);
    font-size: 0.875rem;
    line-height: 1.625;
    margin-bottom: 1.75rem;
    font-family: var(--font-body, sans-serif);
  }
  .social-icons {
    display: flex;
    gap: 0.75rem;
  }
  .social-icons a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.6);
    transition: background 0.3s, transform 0.3s;
  }
  .social-icons a:hover {
    background: #C41E1E;
    color: #fff;
    transform: translateY(-2px);
  }
  .social-icons svg {
    width: 0.875rem;
    height: 0.875rem;
  }

  /* Link columns */
  .footer-col h4 {
    font-size: 0.625rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    font-weight: 600;
    color: #C41E1E;
    margin-bottom: 1.5rem;
    font-family: var(--font-body, sans-serif);
  }
  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-col li {
    margin-bottom: 0.75rem;
  }
  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: rgba(255,255,255,0.35);
    font-size: 0.875rem;
    text-decoration: none;
    font-family: var(--font-body, sans-serif);
    transition: color 0.3s;
  }
  .footer-link:hover {
    color: #fff;
  }
  .footer-link svg {
    width: 0.75rem;
    height: 0.75rem;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .footer-link:hover svg {
    opacity: 1;
  }

  /* Newsletter */
  .footer-newsletter p {
    color: rgba(255,255,255,0.35);
    font-size: 0.875rem;
    line-height: 1.625;
    margin-bottom: 1.25rem;
    font-family: var(--font-body, sans-serif);
  }
  .newsletter-form {
    display: flex;
  }
  .newsletter-form input[type="email"] {
    flex: 1;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 0.75rem 1rem;
    font-size: 0.75rem;
    color: #fff;
    outline: none;
    font-family: var(--font-body, sans-serif);
    transition: border-color 0.3s;
  }
  .newsletter-form input[type="email"]::placeholder {
    color: rgba(255,255,255,0.25);
  }
  .newsletter-form input[type="email"]:focus {
    border-color: #C41E1E;
  }
  .newsletter-btn {
    background: #C41E1E;
    color: #fff;
    border: none;
    padding: 0.75rem 1rem;
    font-size: 0.75rem;
    font-weight: bold;
    letter-spacing: 0.1em;
    cursor: pointer;
    font-family: var(--font-body, sans-serif);
    transition: background 0.3s;
  }
  .newsletter-btn:hover {
    background: #a01818;
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.05);
    padding-top: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }
  .footer-copy {
    color: rgba(255,255,255,0.2);
    font-size: 0.75rem;
    font-family: var(--font-body, sans-serif);
  }
  .footer-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255,255,255,0.15);
    font-size: 0.75rem;
    font-family: var(--font-body, sans-serif);
  }
  .footer-meta .dot {
    width: 0.375rem;
    height: 0.375rem;
    background: #C41E1E;
    display: inline-block;
  }
  .footer-meta a {
    color: inherit;
    text-decoration: none;
    transition: color 0.3s;
  }
  .footer-meta a:hover {
    color: rgba(255,255,255,0.4);
  }
  .footer-meta .separator {
    margin: 0 0.75rem;
  }
{%- endstyle -%}

<footer class="footer">
  <!-- Scrolling marquee -->
  <div class="footer-marquee">
    <div class="marquee-track">
      {%- comment -%} Render the same 8 items twice for seamless loop {%- endcomment -%}
      {%- for i in (1..16) -%}
        {%- assign item = i | modulo: 8 -%}
        {%- if item == 0 -%}
          <span>URBNMYTH.IN&nbsp;&bull;&nbsp;</span>
        {%- else -%}
          <span>URBNMYTH.IN&nbsp;&bull;&nbsp;</span>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <div class="footer-container">
    <div class="footer-grid">
      <!-- Brand column -->
      <div class="brand-col">
        <img
          src="{{ 'URBNMYTHwordmark1.svg' | asset_url }}"
          alt="{{ shop.name }}"
          class="footer-logo"
          width="180"
          height="45"
          style="filter: brightness(0) invert(1);"
          loading="lazy"
        >
        <p class="footer-desc">
          Premium streetwear born in India.<br>
          Old money elegance, new world energy.
        </p>

        <!-- Social icons -->
        <div class="social-icons">
          <!-- Instagram -->
          <a href="#" title="Instagram" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <!-- WhatsApp / MessageCircle -->
          <a href="#" title="WhatsApp" aria-label="WhatsApp">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          </a>
          <!-- Mail -->
          <a href="mailto:hello@urbnmyth.in" title="Email" aria-label="Email">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="footer-col">
        <h4>Shop</h4>
        <ul>
          {%- assign quick_links = "New Arrivals,Best Sellers,T-Shirts,Hoodies,Accessories" | split: ',' -%}
          {%- for link in quick_links -%}
            <li>
              <a href="#" class="footer-link">
                <span>{{ link }}</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </div>

      <!-- Help Links -->
      <div class="footer-col">
        <h4>Help</h4>
        <ul>
          {%- assign help_links = "FAQ,Shipping Info,Returns,Size Guide,Contact Us" | split: ',' -%}
          {%- for link in help_links -%}
            <li>
              <a href="#" class="footer-link">
                <span>{{ link }}</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </div>

      <!-- Newsletter -->
      <div class="footer-col footer-newsletter">
        <h4>Stay Updated</h4>
        <p>
          Drop alerts & style updates straight to your inbox.
        </p>
        <form class="newsletter-form" action="#" method="post" target="_blank">
          <input type="email" name="contact[email]" placeholder="your@email.com" required>
          <button type="submit" class="newsletter-btn">→</button>
        </form>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom">
      <p class="footer-copy">© {{ 'now' | date: '%Y' }} URBNMYTH.IN — All rights reserved.</p>
      <div class="footer-meta">
        <span class="dot"></span>
        <span>Made in India</span>
        <span class="separator">·</span>
        <a href="#">Privacy</a>
        <span class="separator">·</span>
        <a href="#">Terms</a>
      </div>
    </div>
  </div>
</footer>